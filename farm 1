        end
        
    elseif task == "sick" then
        pcall(function() RS.API.ShopAPI.BuyItem:InvokeServer("food", "healing_apple", {buy_count = 1}) end)
        task.wait(1)
        if not ClientData then return end
        local food = ClientData.get_data()[Player.Name].inventory.food or {}
