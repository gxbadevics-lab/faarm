                    for _ = 1, 15 do
                        local curMega = CountPetsByName_AG(petName, "mega")
                        if curMega >= megaGoal then print(petName, "mega goal reached") break end
                        local curNeon   = CountPetsByName_AG(petName, "neon")
                        local curNormal = CountPetsByName_AG(petName, "normal")
                        local total     = (curNeon * 4) + curNormal
                        local counter   = total - (total % 16)
                        if counter <= 0 then print("Not enough", petName, "for mega") break end
                        local ok, pets = pcall(function() return ClientDataAG.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id) == petName and v.properties.neon and not v.properties.mega_neon then
                                    if GetPotions_AG(current_potion_type) > 0 then FGPet_AG(uid) counter -= 4 else break end
                                end
                                task.wait()
                            end
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id) == petName and not v.properties.neon and not v.properties.mega_neon then
                                    if GetPotions_AG(current_potion_type) > 0 then FGPet_AG(uid) counter -= 1 else break end
                                end
                                task.wait()
                            end
                        end
                        if fusionOn then MakeMega_AG(false) MakeMega_AG(true) end
                        if GetPotions_AG(current_potion_type) == 0 then print("Out of potions") break end
                        task.wait(2)
                    end
                end

                -- NEON GOAL
                if neonGoal > 0 then
                    for _ = 1, 15 do
                        local curNeon = CountPetsByName_AG(petName, "neon")
                        if curNeon >= neonGoal then print(petName, "neon goal reached") break end
                        local curNormal = CountPetsByName_AG(petName, "normal")
                        local counter = curNormal - (curNormal % 4)
                        if counter <= 0 then print("Not enough", petName, "for neon") break end
                        local ok, pets = pcall(function() return ClientDataAG.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id) == petName and not v.properties.neon and not v.properties.mega_neon then
                                    if GetPotions_AG(current_potion_type) > 0 then FGPet_AG(uid) counter -= 1 else break end
                                end
                                task.wait()
                            end
                        end
                        if fusionOn then MakeMega_AG(false) end
                        if GetPotions_AG(current_potion_type) == 0 then print("Out of potions") break end
                        task.wait(2)
                    end
                end

                -- NORMAL GOAL
                if normalGoal > 0 then
                    for _ = 1, 15 do
                        local fullNormal = 0
                        local ok, pets = pcall(function() return ClientDataAG.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for _, v in pairs(pets) do
                                if findPetDisplayName(v.id) == petName and not v.properties.neon and not v.properties.mega_neon and v.properties.age == 6 then
                                    fullNormal += 1
                                end
                            end
                        end
                        if fullNormal >= normalGoal then print(petName, "normal goal reached") break end
                        local counter = normalGoal - fullNormal
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id) == petName and not v.properties.neon and not v.properties.mega_neon and v.properties.age < 6 then
                                    if GetPotions_AG(current_potion_type) > 0 then FGPet_AG(uid) counter -= 1 else break end
                                end
                                task.wait()
                            end
                        end
                        if GetPotions_AG(current_potion_type) == 0 then print("Out of potions") break end
                        task.wait(2)
                    end
                end

                print("Done:", petName)
                task.wait(3)
            end
        end)
        task.wait(120)
    end
