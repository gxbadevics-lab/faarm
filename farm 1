local function getFullgrownForFusion(forMega)
    local result = {}
    local ok, pets = pcall(function() return ClientDataAG.get_data()[Player.Name].inventory.pets end)
    if not ok then return result end
    for _, v in pairs(pets) do
        local match = forMega
            and (v.properties.age == 6 and v.properties.neon and not v.properties.mega_neon)
            or (not forMega and v.properties.age == 6 and not v.properties.neon and not v.properties.mega_neon)
        if match then
            if not result[v.id] then result[v.id] = {count=0, unique={}} end
            result[v.id].count += 1
            table.insert(result[v.id].unique, v.unique)
            if result[v.id].count >= 4 then break end
        end
    end
    return result
end

local function MakeMega_AG(forMega)
    repeat
        local ready = {}
        for _, g in pairs(getFullgrownForFusion(forMega)) do
            if g.count >= 4 then
                ready = {g.unique[1], g.unique[2], g.unique[3], g.unique[4]}
                break
            end
        end
        if #ready >= 4 then
            pcall(function()
                ReplicatedStorage.API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer({unpack(ready)})
            end)
            task.wait(0.5)
        end
    until #ready < 4
end

local function CountPetsByName_AG(displayName, petType)
    local c = 0
    local ok, pets = pcall(function() return ClientDataAG.get_data()[Player.Name].inventory.pets end)
    if not ok then return 0 end
    for _, v in pairs(pets) do
        local nameMatch = findPetDisplayName(v.id) == displayName
        local typeMatch = (petType=="normal" and not v.properties.neon and not v.properties.mega_neon)
            or (petType=="neon" and v.properties.neon and not v.properties.mega_neon)
            or (petType=="mega" and v.properties.mega_neon == true)
        if nameMatch and typeMatch then c += 1 end
        task.wait()
    end
    return c
end

