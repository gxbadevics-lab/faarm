-- Main baby farm loop (updated section)
function startBabyFarm(uiElements)
    spawn(function()
        local startTime = os.time()
        
        while _G.autofarm do
            pcall(function()
                if babyFarmEnabled then
                    -- Check if we're a baby
                    if not isPlayerBaby() then
                        if uiElements and uiElements.statusLabel then
                            uiElements.statusLabel.Text = "Status: Becoming Baby..."
                        end
                        becomeBaby()
                        task.wait(5)
                    else
                        if uiElements and uiElements.statusLabel then
                            uiElements.statusLabel.Text = "Status: Baby Mode Active"
                        end
                        
                        -- Get baby needs using improved function
                        local babyAilments = getBabyAilments()
                        
                        -- Debug print every 30 seconds to see what's available
                        if math.random(1, 30) == 1 then
                            debugBabyNeeds()
                        end
                        
                        -- Find furniture if needed
                        if not babyCrib then
                            babyCrib = getBabyFurniture("crib")
                        end
                        if not babyShower then
                            babyShower = getBabyFurniture("shower")
                        end
                        if not babyHighChair then
                            babyHighChair = getBabyFurniture("highchair")
                        end
                        
                        -- Update furniture status
                        if uiElements and uiElements.furnitureLabel then
                            uiElements.furnitureLabel.Text = string.format(
                                "Furniture:\nCrib: %s | Shower: %s | Chair: %s",
                                babyCrib and "✓" or "?",
                                babyShower and "✓" or "?",
                                babyHighChair and "✓" or "?"
                            )
                        end
                        
                        -- Update needs display
                        if uiElements and uiElements.needsLabel then
                            if babyAilments and next(babyAilments) then
                                local needs = ""
                                for need, value in pairs(babyAilments) do
                                    -- Format the need name nicely
                                    local displayNeed = tostring(need):gsub("_", " "):gsub("^%l", string.upper)
                                    needs = needs .. displayNeed .. "  "
                                end
                                uiElements.needsLabel.Text = "Baby Needs: " .. needs
                            else
                                uiElements.needsLabel.Text = "Baby Needs: None (checking...)"
                            end
                        end
                        
                        -- Update time
                        if uiElements and uiElements.timeLabel then
                            local elapsedTime = os.difftime(os.time(), startTime)
                            local elapsedMinutes = math.floor(elapsedTime / 60)
                            local elapsedHours = math.floor(elapsedMinutes / 60)
                            uiElements.timeLabel.Text = "Time: " .. elapsedHours .. "h " .. elapsedMinutes % 60 .. "min"
                        end
                        
                        -- Handle baby needs
                        if babyAilments and not isBabyDoingTask then
                            -- Convert ailments to lowercase for comparison
                            local ailmentsLower = {}
                            for k, v in pairs(babyAilments) do
                                ailmentsLower[tostring(k):lower()] = v
                            end
                            
                            -- Sleepy
                            if (ailmentsLower.sleepy or ailmentsLower.sleep) and babyCrib then
                                print("Baby is sleepy - using crib")
                                isBabyDoingTask = "sleepy"
                                if uiElements and uiElements.statusLabel then
                                    uiElements.statusLabel.Text = "Status: Putting to Sleep"
                                end
                                
                                GoToHome()
                                task.wait(1)
                                
                                pcall(function()
                                    local api = ReplicatedStorage.API:FindFirstChild("HousingAPI/ActivateFurniture")
                                    if api and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                                        local args = {
                                            [1] = Player,
                                            [2] = babyCrib:sub(#Player.Name + 13),
                                            [3] = "UseBlock",
                                            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                                            [5] = Player.Character
                                        }
                                        api:InvokeServer(unpack(args))
                                    end
                                end)
                                
                                task.wait(15)
                                isBabyDoingTask = false
                                
                            -- Dirty
                            elseif (ailmentsLower.dirty or ailmentsLower.bath) and babyShower then
                                print("Baby is dirty - using shower")
                                isBabyDoingTask = "dirty"
                                if uiElements and uiElements.statusLabel then
                                    uiElements.statusLabel.Text = "Status: Bathing"
                                end
                                
                                GoToHome()
                                task.wait(1)
                                
                                pcall(function()
                                    local api = ReplicatedStorage.API:FindFirstChild("HousingAPI/ActivateFurniture")
                                    if api and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                                        local args = {
                                            [1] = Player,
                                            [2] = babyShower:sub(#Player.Name + 13),
                                            [3] = "UseBlock",
                                            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                                            [5] = Player.Character
                                        }
                                        api:InvokeServer(unpack(args))
                                    end
                                end)
                                
                                task.wait(15)
                                isBabyDoingTask = false
                                
                            -- Hungry/Thirsty
                            elseif (ailmentsLower.hungry or ailmentsLower.thirsty or ailmentsLower.feed) and babyHighChair then
                                print("Baby needs food/drink - using highchair")
                                isBabyDoingTask = "feeding"
                                if uiElements and uiElements.statusLabel then
                                    uiElements.statusLabel.Text = "Status: Feeding"
                                end
                                
                                GoToHome()
                                task.wait(1)
                                
                                -- Put in high chair
                                pcall(function()
                                    local api = ReplicatedStorage.API:FindFirstChild("HousingAPI/ActivateFurniture")
                                    if api and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                                        local chairArgs = {
                                            [1] = Player,
                                            [2] = babyHighChair:sub(#Player.Name + 13),
                                            [3] = "Seat1",
                                            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                                            [5] = Player.Character
                                        }
                                        api:InvokeServer(unpack(chairArgs))
                                    end
                                end)
                                
                                task.wait(2)
                                
                                -- Get baby bottle
                                local Foods = {}
                                pcall(function()
                                    Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
                                end)
                                
                                local babyBottle = nil
                                for i, v in pairs(Foods) do
                                    if v.id == "baby_bottle" then
                                        babyBottle = v.unique
                                        break
                                    end
                                end
                                
                                if not babyBottle then
                                    pcall(function()
                                        local api = ReplicatedStorage.API:FindFirstChild("ShopAPI/BuyItem")
                                        if api then
                                            api:InvokeServer("food", "baby_bottle", {["buy_count"] = 1})
                                        end
                                    end)
                                    task.wait(2)
                                    
                                    pcall(function()
                                        Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
                                    end)
                                    for i, v in pairs(Foods) do
                                        if v.id == "baby_bottle" then
                                            babyBottle = v.unique
                                            break
                                        end
                                    end
                                end
                                
                                if babyBottle then
                                    pcall(function()
                                        local equipApi = ReplicatedStorage.API:FindFirstChild("ToolAPI/Equip")
                                        if equipApi then
                                            equipApi:InvokeServer(babyBottle, {
                                                use_sound_delay = true,
                                                equip_as_last = false
                                            })
                                        end
                                    end)
                                    
                                    task.wait(1)
                                    
                                    pcall(function()
                                        local useApi = ReplicatedStorage.API:FindFirstChild("ToolAPI/ServerUseTool")
                                        if useApi then
                                            useApi:FireServer(babyBottle, "START")
                                        end
                                    end)
                                    
                                    task.wait(4)
                                    
                                    pcall(function()
                                        local useApi = ReplicatedStorage.API:FindFirstChild("ToolAPI/ServerUseTool")
                                        if useApi then
                                            useApi:FireServer(babyBottle, "END")
                                        end
                                        local unequipApi = ReplicatedStorage.API:FindFirstChild("ToolAPI/Unequip")
                                        if unequipApi then
                                            unequipApi:InvokeServer(babyBottle)
                                        end
                                    end)
                                end
                                
                                task.wait(5)
                                isBabyDoingTask = false
                            end
                        end
                    end
                else
                    -- If disabled, make sure we're parent
                    if isPlayerBaby() then
                        becomeParent()
                    end
                    task.wait(1)
                end
            end)
            task.wait(2)
        end
    end)
end
