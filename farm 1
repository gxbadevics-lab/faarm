function createLabel(frame, position, text)
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(0, 300, 0, 50)  -- Size of the TextLabel
    textLabel.Position = UDim2.new(0.5, 0, position, 0)  -- Position at the center
    textLabel.AnchorPoint = Vector2.new(0.5, 0.5)  -- Adjust the anchor point to the center
    textLabel.TextScaled = true  -- Scale the text to fit the TextLabel
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)  -- White text color
    textLabel.Font = Enum.Font.SourceSansBold  -- Choose a font
    textLabel.Text = text  -- Set the text to the player's name
    textLabel.BackgroundTransparency = 1  -- Make the background of the TextLabel transparent
    textLabel.ZIndex = 11  -- Ensure it's above the Frame
    textLabel.Parent = frame
    return textLabel
end

