    end
    print("Changed to pet:", pet["id"], "Age:", pet["properties"]["age"], "IsEgg:", isEgg(pet["id"]))
end

-- IMPROVED: Hatch egg
function hatchEgg(pet_unique, petID)
    print("Hatching egg:", petID)
    
    -- Make sure egg is equipped
    pcall(function()
        RS:WaitForChild("API"):WaitForChild("ToolAPI/Equip"):InvokeServer(pet_unique)
    end)
    task.wait(1)
    
    -- Try to use age potion to hatch
    local potionUsed = false
    local potionTypes = {"pet_age_potion", "tiny_pet_age_potion"}
    
    for _, potType in ipairs(potionTypes) do
        if not potionUsed then
            -- Find potion
            local potionId = nil
            for l, o in pairs(ClientData.get_data()[Player.Name].inventory.food) do
                if o.id == potType then 
                    potionId = l 
                    break
                end
            end
            
            if potionId then
                pcall(function()
                    RouterClient.get("PetObjectAPI/CreatePetObject"):InvokeServer(
                        "__Enum_PetObjectCreatorType_2",
                        {pet_unique = pet_unique, unique_id = potionId, additional_consume_uniques = {}}
                    )
                    task.wait(1)
                    
                    -- Find and consume the potion object
                    for _, obj in pairs(workspace.PetObjects:GetChildren()) do
                        if obj:IsA("Model") and obj:FindFirstChild("OwnerPlayer") then
                            local owner = obj:FindFirstChild("OwnerPlayer")
                            if owner and owner.Value == Player then
                                RouterClient.get("PetAPI/ConsumeFoodObject"):FireServer(obj, pet_unique)
                                potionUsed = true
                                print("Used", potType, "to hatch egg")
                                break
                            end
                        end
                    end
                end)
            end
        end
        if potionUsed then break end
        task.wait(1)
    end
    
    if not potionUsed then
        print("No potions to hatch egg - will try again later")
    end
    
    task.wait(3)
end

-- IMPROVED: Check if we need to change pet
function checkIfINeedToChange()
    local ok, Pets = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets or {}
    end)
    if not ok then return end

    -- If no pet equipped, definitely need to switch
    if not Pet or not PetID then
        local best = getPetToFarm()
        if best then
            changePetTo(best)
        end
        return
    end

    -- Check current pet
    local currentPetData = nil
    local ok2, curPet = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets[tostring(PetID)]
    end)
    
    if ok2 and curPet then
        currentPetData = curPet
        
        -- If current pet is an egg, hatch it
        if isEgg(curPet["id"]) then
            print("Current pet is an egg - hatching")
            hatchEgg(PetID, curPet["id"])
            task.wait(2)
            -- After hatching, find new pet
            local best = getPetToFarm()
            if best then
                changePetTo(best)
            end
            return
        end
        
        -- If current pet is full grown, check if we have eggs or higher age pets
        if curPet["properties"]["age"] == 6 then
            -- Look for eggs first
            for _, v in pairs(Pets) do
                if v["id"] ~= "practice_dog" and isEgg(v["id"]) then
                    print("Found egg while current pet is full grown - switching")
                    changePetTo(v)
                    return
                end
            end
            
            -- Look for non-full grown pets
            for _, v in pairs(Pets) do
                if v["id"] ~= "practice_dog" and not isEgg(v["id"]) and v["properties"]["age"] < 6 then
                    print("Found younger pet while current is full grown - switching")
                    changePetTo(v)
                    return
                end
            end
        end
    else
        -- Current pet data not found, switch
        local best = getPetToFarm()
        if best then
            changePetTo(best)
        end
    end
    
    -- EGG FARM: Check if we need to buy new eggs
    if autoEggFarm then
        spawn(function()
            -- Count pets
            local hasEggs = false
            local hasGrowable = false
            
            for _, v in pairs(Pets) do
                if v["id"] ~= "practice_dog" then
                    if isEgg(v["id"]) then
                        hasEggs = true
                    elseif v["properties"]["age"] < 6 then
                        hasGrowable = true
                    end
                end
            end
            
            -- If no eggs AND no growable pets, buy a new egg
            if not hasEggs and not hasGrowable then
                print("No eggs or growable pets - buying new egg")
                pcall(function()
                    RS.API:FindFirstChild("ShopAPI/BuyItem"):InvokeServer("pets", eggToBuy, {buy_count = 1})
                end)
                task.wait(2)
            end
        end)
    end
end

