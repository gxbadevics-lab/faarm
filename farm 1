-- Check and switch pets
function checkIfINeedToChange()
    if not ClientData then return end
    local ok, Pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets or {} end)
    if not ok then return end
    
    local currentPetData = nil
    if PetID then
        pcall(function() currentPetData = ClientData.get_data()[Player.Name].inventory.pets[tostring(PetID)] end)
    end
    
    if not Pet or not PetID or not currentPetData then
        local best = getPetToFarm()
        if best then
            changePetTo(best)
        end
        return
    end
    
    -- If current pet is full grown OR hatched (egg with age > 0 becomes pet), check for better options
    if currentPetData.properties.age == 6 or (isEgg(currentPetData.id) and currentPetData.properties.age > 0) then
        -- Look for unhatched eggs first
        for _, v in pairs(Pets) do
            if v.id ~= "practice_dog" and isEgg(v.id) and v.properties.age == 0 then
                print("Found unhatched egg, switching to grow it...")
                changePetTo(v)
                return
            end
        end
        
        -- Look for non-full grown
        for _, v in pairs(Pets) do
            if v.id ~= "practice_dog" and not (isEgg(v.id) and v.properties.age == 0) and v.properties.age < 6 then
                print("Found younger pet, switching...")
                changePetTo(v)
                return
            end
        end
    end
    
    -- Auto buy eggs if needed (when no pets left)
    if autoEggFarm then
        spawn(function()
            local hasAnyPet = false
            local hasUnhatchedEgg = false
            
            for _, v in pairs(Pets) do
                if v.id ~= "practice_dog" then
                    hasAnyPet = true
                    if isEgg(v.id) and v.properties.age == 0 then
                        hasUnhatchedEgg = true
                    end
                end
            end
            
            -- If no pets at all, or only full grown pets with no eggs to grow
            if not hasAnyPet then
                print("No pets at all, buying new egg...")
                pcall(function() RS.API.ShopAPI.BuyItem:InvokeServer("pets", eggToBuy, {buy_count = 1}) end)
                task.wait(2)
            elseif not hasUnhatchedEgg then
                -- Check if all pets are full grown
                local allFullGrown = true
                for _, v in pairs(Pets) do
                    if v.id ~= "practice_dog" and v.properties.age < 6 then
                        allFullGrown = false
                        break
                    end
                end
                if allFullGrown then
                    print("All pets full grown, buying new egg to grow...")
                    pcall(function() RS.API.ShopAPI.BuyItem:InvokeServer("pets", eggToBuy, {buy_count = 1}) end)
                    task.wait(2)
                end
            end
        end)
    end
end

