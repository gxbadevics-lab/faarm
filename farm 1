-- AUTO AGE (neon + mega fusion using potion method)
---------------------------------------------------------------------
local current_potion_type = "pet_age_potion"

function FGPet(petID)
    if CheckFG(petID) then
        print("Already full grown:", petID)
        return
    end
    pcall(function()
        RS:WaitForChild("API"):WaitForChild("ToolAPI/Equip"):InvokeServer(petID)
        repeat task.wait() until ClientData.get_data()[Player.Name].pet_char_wrappers[1]

        while task.wait() do
            local wrapper = ClientData.get_data()[Player.Name].pet_char_wrappers[1]
            if not wrapper or wrapper.pet_progression["age"] >= 6 then break end

            local potionId    = nil
            local potionTable = {}
            local potionCount = GetMultiPotCount(petID, current_potion_type)

            for l, o in pairs(ClientData.get_data()[Player.Name].inventory.food) do
                if o.id == current_potion_type then
                    if not potionId then
                        potionId = l
                    else
                        if #potionTable + 1 < potionCount then
                            table.insert(potionTable, l)
                        end
                    end
                end
            end

            if not potionId then
                -- try tiny potion fallback
                if current_potion_type == "pet_age_potion" then
                    current_potion_type = "tiny_pet_age_potion"
                    return FGPet(petID)
                else
                    current_potion_type = "pet_age_potion"
                    print("Out of potions!")
                    break
                end
            end

            if CheckPetEquipID(petID) then
                task.wait(1)
                local ok, _ = pcall(function()
                    RouterClient.get("PetObjectAPI/CreatePetObject"):InvokeServer(
                        "__Enum_PetObjectCreatorType_2",
                        {pet_unique = petID, unique_id = potionId, additional_consume_uniques = potionTable}
                    )
                end)
                if ok then
                    repeat task.wait()
                        pcall(function()
                            RouterClient.get("PetAPI/ConsumeFoodObject"):FireServer(
                                workspace.PetObjects:FindFirstChildWhichIsA("Model"), petID)
                        end)
                    until not (workspace.PetObjects:FindFirstChild("AgePotion") or workspace.PetObjects:FindFirstChild("TinyAgePotion"))
                end
            else
                break
            end
        end
        print("FG done:", petID)
    end)
end

