        if not Apple then
            pcall(function() RS.API.ShopAPI.BuyItem:InvokeServer("food", "apple", {buy_count = 1}) end)
            task.wait(1)
        end
        if Apple then
            pcall(function() RS.API.AdoptAPI.EatFood:FireServer(Apple) end)
