local function disableEffects(obj)
    pcall(function()
        if obj:IsA("Part") or obj:IsA("UnionOperation") or obj:IsA("MeshPart") or obj:IsA("CornerWedgePart") or obj:IsA("TrussPart") then
            obj.Material = Enum.Material.SmoothPlastic obj.Reflectance = 0
        elseif obj:IsA("Decal") then obj.Transparency = 0
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then obj.Lifetime = NumberRange.new(0)
        elseif obj:IsA("Explosion") then obj.BlastPressure = 0 obj.BlastRadius = 0
        elseif obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("SpotLight") or obj:IsA("Sparkles") then obj.Enabled = false
        end
    end)
end

local function disableVisualEffects(eff)
    pcall(function()
        if eff:IsA("BlurEffect") or eff:IsA("SunRaysEffect") or eff:IsA("ColorCorrectionEffect")
            or eff:IsA("BloomEffect") or eff:IsA("DepthOfFieldEffect") then eff.Enabled = false end
    end)
end

local function applyFullBright()
    pcall(function()
        local L = game:GetService("Lighting")
        L.FogColor=Color3.new(1,1,1) L.FogEnd=math.huge L.FogStart=math.huge
        L.Ambient=Color3.new(1,1,1) L.Brightness=5
        L.ColorShift_Bottom=Color3.new(1,1,1) L.ColorShift_Top=Color3.new(1,1,1)
        L.OutdoorAmbient=Color3.new(1,1,1) L.Outlines=true
    end)
end

local function disableAssets()
    pcall(function()
        local T = workspace:FindFirstChildOfClass("Terrain")
        T.WaterWaveSize=0 T.WaterWaveSpeed=0 T.WaterReflectance=0 T.WaterTransparency=0
        local L = game:GetService("Lighting")
        L.GlobalShadows=false L.FogEnd=9e9 L.Brightness=0
        settings().Rendering.QualityLevel="Level01"
        for _, obj in pairs(game:GetDescendants()) do disableEffects(obj) end
        for _, eff in pairs(L:GetChildren()) do disableVisualEffects(eff) end
    end)
end

local function removeUnwantedObjects()
    workspace.DescendantAdded:Connect(function(child)
        task.spawn(function()
            pcall(function()
                if child:IsA("ForceField") or child:IsA("Sparkles") or child:IsA("SpotLight")
                    or child:IsA("Smoke") or child:IsA("Fire") then child:Destroy() end
            end)
        end)
    end)
    for _, obj in pairs(workspace:GetDescendants()) do
        pcall(function()
            if obj:IsA("Animator") or obj:IsA("ParticleEmitter") or obj:IsA("Sound") then obj:Destroy() end
        end)
    end
end

