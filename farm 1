            local env = getfenv(v)
            if env and env.script == ReplicatedStorage.ClientModules.Core.InteriorsM.InteriorsM then
                local constants = getconstants(v)
                if constants and table.find(constants, "LocationAPI/SetLocation") then
                    Location = v
                    break
                end
            end
        end
    end
end)

local function SetLocation(a, b, c)
    if not Location then return false end
    local k = get_thread_identity and get_thread_identity() or 2
    pcall(set_thread_identity, 2)
    wait()
    pcall(Location, a, b, c)
    pcall(set_thread_identity, k)
    wait()
    return true
end

function GoToHome()
