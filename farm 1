-- Get baby ailments/tasks the same way as pets, but filter for baby-specific ones
function getBabyAilments()
    -- Baby-specific tasks (similar to pet tasks but for babies)
    local babyTasks = {
        "hungry",
        "sleepy",
        "thirsty",
        "dirty",
        "bored",
        "sick"
    }
    
    local ailments = {}
    
    -- Try to get client data (same method as pets)
    local success, data = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
    end)
    
    if success and data then
        -- Check baby_manager the same way pets check ailments
        if data.baby_manager then
            -- Check ailments table (same structure as pets)
            if data.baby_manager.ailments then
                for k, v in pairs(data.baby_manager.ailments) do
                    if table.find(babyTasks, k) then
                        ailments[k] = v
                        print("Found baby task via ailments:", k)
                    end
                end
            end
            
            -- Check needs table
            if data.baby_manager.needs then
                for k, v in pairs(data.baby_manager.needs) do
                    if table.find(babyTasks, k) then
                        ailments[k] = v
                        print("Found baby task via needs:", k)
                    end
                end
            end
            
            -- Check active_ailments
            if data.baby_manager.active_ailments then
                for k, v in pairs(data.baby_manager.active_ailments) do
                    if table.find(babyTasks, k) then
                        ailments[k] = v
                        print("Found baby task via active_ailments:", k)
                    end
                end
            end
        end
        
        -- Check baby_status
        if data.baby_status then
            for k, v in pairs(data.baby_status) do
                if type(v) == "table" and v.active and table.find(babyTasks, k) then
                    ailments[k] = v
                    print("Found baby task via baby_status:", k)
                elseif type(v) == "boolean" and v and table.find(babyTasks, k) then
                    ailments[k] = v
                    print("Found baby task via baby_status bool:", k)
                end
            end
        end
        
        -- Check player ailments (might be stored with player data)
        if data.ailments_manager and data.ailments_manager.ailments then
            for petId, petAilments in pairs(data.ailments_manager.ailments) do
                -- This is for pets, but babies might be stored as a special ID
                if petId == "baby" or petId == "player" then
                    for k, v in pairs(petAilments) do
                        if table.find(babyTasks, k) then
                            ailments[k] = v
                            print("Found baby task in ailments_manager:", k)
                        end
                    end
                end
            end
        end
    end
    
    -- Check GUI for baby tasks (like the pet task monitor but for babies)
    if Player and Player.PlayerGui then
        -- Check for BabyApp
        local babyGui = Player.PlayerGui:FindFirstChild("BabyApp") or Player.PlayerGui:FindFirstChild("BabyMonitor")
        if babyGui then
            for _, child in pairs(babyGui:GetDescendants()) do
                if child:IsA("TextLabel") and child.Text then
                    local text = child.Text:lower()
                    for _, task in pairs(babyTasks) do
                        if text:find(task) then
                            ailments[task] = true
                            print("Found baby task in GUI:", task)
                        end
                    end
                end
            end
        end
        
        -- Check for task icons
        for _, gui in pairs(Player.PlayerGui:GetChildren()) do
            if gui.Name:lower():find("task") or gui.Name:lower():find("need") or gui.Name:lower():find("baby") then
                for _, child in pairs(gui:GetDescendants()) do
                    if child:IsA("ImageLabel") or child:IsA("TextLabel") then
                        -- Check image names for task indicators
                        if child:IsA("ImageLabel") and child.Image then
                            local image = child.Image:lower()
                            for _, task in pairs(babyTasks) do
                                if image:find(task) then
                                    ailments[task] = true
                                    print("Found baby task via image:", task)
                                end
                            end
                        end
                        -- Check text labels
                        if child:IsA("TextLabel") and child.Text then
                            local text = child.Text:lower()
                            for _, task in pairs(babyTasks) do
                                if text:find(task) then
                                    ailments[task] = true
                                    print("Found baby task via text:", task)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- Check character for task indicators
    if Player.Character then
        for _, child in pairs(Player.Character:GetDescendants()) do
            if child:IsA("BillboardGui") then
                for _, text in pairs(child:GetDescendants()) do
                    if text:IsA("TextLabel") and text.Text then
                        local textContent = text.Text:lower()
                        for _, task in pairs(babyTasks) do
                            if textContent:find(task) then
                                ailments[task] = true
                                print("Found baby task on character:", task)
                            end
                        end
                    end
                end
            end
        end
    end
    
    return ailments
end

function getBabyFurniture(type)
    GoToHome()
    task.wait(2)
    
    if not workspace.HouseInteriors or not workspace.HouseInteriors.furniture then
        return nil
    end
    
    for i, v in pairs(workspace.HouseInteriors.furniture:GetChildren()) do
        if v:FindFirstChildWhichIsA("Model") then
            local Furniture = v:FindFirstChildWhichIsA("Model")
            local furnitureName = Furniture.Name:lower()
            
            if type == "crib" and (furnitureName:find("crib") or (furnitureName:find("bed") and furnitureName:find("baby"))) then
                print("Found crib: " .. v.Name)
                return v.Name
            elseif type == "shower" and (furnitureName:find("shower") or furnitureName:find("bath") or furnitureName:find("tub")) then
                print("Found shower: " .. v.Name)
                return v.Name
            elseif type == "highchair" and furnitureName:find("highchair") then
                print("Found highchair: " .. v.Name)
                return v.Name
            end
        end
    end
    return nil
end

