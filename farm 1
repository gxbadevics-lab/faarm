-- Check if pet is an egg
function isEgg(petID)
    if not InventoryDB then
        -- fallback: check id contains "egg"
        return string.find(string.lower(tostring(petID)), "egg") ~= nil
    end
    for _, entry in pairs(InventoryDB.pets) do
        if type(entry) == "table" and string.lower(tostring(entry.id)) == string.lower(tostring(petID)) then
            return entry.is_egg == true
        end
    end
    return false
end

