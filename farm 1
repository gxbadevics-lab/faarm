-- IMPROVED: Get best pet to farm
function getPetToFarm()
    local ok, Pets = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets or {}
    end)
    if not ok then return nil end
    
    -- FIRST PRIORITY: Find any eggs to hatch
    for _, v in pairs(Pets) do
        if v["id"] ~= "practice_dog" and isEgg(v["id"]) then
            print("Found egg to hatch:", v["id"])
            return v
        end
    end
    
    -- SECOND PRIORITY: Look for pets that are NOT full grown
    local candidates = {}
    for _, v in pairs(Pets) do
        if v["id"] ~= "practice_dog" and not isEgg(v["id"]) then
            if v["properties"]["age"] < 6 then
                -- Calculate priority: neons get +10 bonus, higher age = higher priority
                local priority = v["properties"]["age"]
                if v["properties"]["neon"] then
                    priority = priority + 10
                end
                table.insert(candidates, {pet = v, priority = priority})
            end
        end
    end
    
    -- Sort by priority (highest first)
    table.sort(candidates, function(a, b) return a.priority > b.priority end)
    
    if #candidates > 0 then
        return candidates[1].pet
    end
    
    -- THIRD PRIORITY: Any non-egg pet (even if full grown - for trading)
    for _, v in pairs(Pets) do
        if v["id"] ~= "practice_dog" and not isEgg(v["id"]) then
            return v
        end
    end
    
    return nil
end

function changePetTo(pet)
