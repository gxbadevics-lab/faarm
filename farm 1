-- Simple Baby Task Detector
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Player = Players.LocalPlayer

print("=== BABY TASK DETECTOR STARTED ===")

-- Wait for game to load
repeat task.wait(1) until Player and Player.Character

-- Function to become baby
function becomeBaby()
    print("Attempting to become baby...")
    pcall(function()
        local args = {
            [1] = "Babies",
            [2] = {
                ["dont_respawn"] = true,
                ["source_for_logging"] = "avatar_editor"
            }
        }
        ReplicatedStorage.API.TeamAPI.ChooseTeam:InvokeServer(unpack(args))
    end)
end

-- Function to check if we're baby
function isBaby()
    return Player.Team and Player.Team.Name == "Babies"
end

-- Simple task scanner
function scanForBabyTasks()
    print("\n=== SCANNING FOR BABY TASKS ===")
    print("Time:", os.date())
    print("Is Baby:", isBaby())
    
    -- METHOD 1: Check Client Data
    local success, data = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
    end)
    
    if success and data then
        print("\n--- CLIENT DATA SCAN ---")
        
        -- Check every field for baby-related data
        for fieldName, fieldValue in pairs(data) do
            if type(fieldName) == "string" and fieldName:lower():find("baby") then
                print("Found baby field:", fieldName)
                if type(fieldValue) == "table" then
                    for k, v in pairs(fieldValue) do
                        print("  ", k, ":", type(v))
                        if type(v) == "table" then
                            for k2, v2 in pairs(v) do
                                print("    ", k2, ":", tostring(v2))
                            end
                        end
                    end
                end
            end
        end
        
        -- Check specifically for ailments/needs
        if data.baby_manager then
            print("\n--- BABY MANAGER CONTENTS ---")
            for k, v in pairs(data.baby_manager) do
                print("  " .. tostring(k) .. ":")
                if type(v) == "table" then
                    for k2, v2 in pairs(v) do
                        print("    " .. tostring(k2) .. ":", tostring(v2))
                    end
                else
                    print("    ", tostring(v))
                end
            end
        end
        
        if data.baby_status then
            print("\n--- BABY STATUS CONTENTS ---")
            for k, v in pairs(data.baby_status) do
                print("  " .. tostring(k) .. ":", tostring(v))
            end
        end
        
        -- Check if any pet ailments are actually for baby
        if data.ailments_manager and data.ailments_manager.ailments then
            print("\n--- CHECKING PET AILMENTS FOR BABY ---")
            for petId, petAilments in pairs(data.ailments_manager.ailments) do
                if petId == "baby" or petId == "player" or petId == "self" then
                    print("  Found baby in pet ailments:")
                    for k, v in pairs(petAilments) do
                        print("    " .. tostring(k) .. ":", tostring(v))
                    end
                end
            end
        end
    else
        print("Failed to get client data")
    end
    
    -- METHOD 2: Check GUI
    print("\n--- GUI SCAN ---")
    if Player.PlayerGui then
        for _, gui in pairs(Player.PlayerGui:GetChildren()) do
            if gui.Name:lower():find("baby") or gui.Name:lower():find("task") or gui.Name:lower():find("need") then
                print("Found GUI:", gui.Name)
                -- Scan for text
                for _, child in pairs(gui:GetDescendants()) do
                    if child:IsA("TextLabel") and child.Text and child.Text ~= "" then
                        print("  Text:", child.Text)
                    end
                end
            end
        end
    end
    
    -- METHOD 3: Check Character
    print("\n--- CHARACTER SCAN ---")
    if Player.Character then
        for _, child in pairs(Player.Character:GetDescendants()) do
            if child:IsA("BillboardGui") then
                print("Found BillboardGui:", child.Name)
                for _, text in pairs(child:GetDescendants()) do
                    if text:IsA("TextLabel") and text.Text and text.Text ~= "" then
                        print("  Text:", text.Text)
                    end
                end
            end
        end
    end
    
    print("=== SCAN COMPLETE ===\n")
end

-- Main loop
spawn(function()
    -- First become baby
    if not isBaby() then
        print("Becoming baby...")
        becomeBaby()
        task.wait(5)
    end
    
    -- Scan every 10 seconds
    while true do
        scanForBabyTasks()
        task.wait(10)
    end
end)

print("Baby Task Detector Running - Check output in console (F9)")
