function findWord(str, word)
    return string.match(str, "%f[%w]"..word.."%f[%W]") ~= nil
end

function table_contains(tbl, x)
    for _, v in pairs(tbl) do
        if v == x then return true end
    end
    return false
end

function lastPart(s, symbol)
    return s:match(".*"..symbol.."(.*)")
end

