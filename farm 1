local function petMatchesTrade(v)
    for _, v2 in pairs(petsToTrade) do
        if v2=="FullGrown"              and v["properties"]["age"]==6 and not v["properties"]["neon"] and not v["properties"]["mega_neon"] then return true end
        if v2=="Luminous Neon"          and v["properties"]["age"]==6 and v["properties"]["neon"] and not v["properties"]["mega_neon"] then return true end
        if v2=="All Neon"               and v["properties"]["neon"] then return true end
        if v2=="Mega"                   and v["properties"]["mega_neon"] then return true end
        if v2=="All Legendaries"        and table_contains(legendaryPets, v["id"]) then return true end
        if v2=="Full Grown Legendaries" and table_contains(legendaryPets, v["id"]) and v["properties"]["age"]==6 then return true end
        if v2=="Eggs"                   and EggsWPrice[v["id"]] then return true end
        if v2=="All Pets"               then return true end
        if v2=="All Common"             and allGamePets[v["id"]] and allGamePets[v["id"]].rarity=="common" then return true end
        if v2=="Full Grown Common"      and allGamePets[v["id"]] and allGamePets[v["id"]].rarity=="common"      and v["properties"]["age"]==6 then return true end
        if v2=="All Uncommon"           and allGamePets[v["id"]] and allGamePets[v["id"]].rarity=="uncommon" then return true end
        if v2=="Full Grown Uncommon"    and allGamePets[v["id"]] and allGamePets[v["id"]].rarity=="uncommon"    and v["properties"]["age"]==6 then return true end
        if v2=="All Rare"               and allGamePets[v["id"]] and allGamePets[v["id"]].rarity=="rare" then return true end
        if v2=="Full Grown Rare"        and allGamePets[v["id"]] and allGamePets[v["id"]].rarity=="rare"         and v["properties"]["age"]==6 then return true end
        if v2=="All Ultra Rare"         and allGamePets[v["id"]] and allGamePets[v["id"]].rarity=="ultra_rare" then return true end
        if v2=="Full Grown Ultra Rare"  and allGamePets[v["id"]] and allGamePets[v["id"]].rarity=="ultra_rare"  and v["properties"]["age"]==6 then return true end
    end
    return false
end

