local function matchesTrade(v, entry)
    if entry == "ALL_MEGA"   then return v.properties.mega_neon == true end
    if entry == "ALL_NEON"   then return v.properties.neon == true and v.properties.age == 6 and not v.properties.mega_neon end
    if entry == "ALL_FG"     then return v.properties.age == 6 and not v.properties.neon and not v.properties.mega_neon end
    if entry == "ALL_PETS"   then return true end

    local parts   = string.split(entry, ",")
    local petKind = parts[1]
    local variant = parts[2]

    if string.lower(tostring(v.id)) ~= string.lower(petKind) then return false end
    if not variant then return true end
    if variant == "mega" and not v.properties.mega_neon then return false end
    if variant == "neon" and (not v.properties.neon or v.properties.mega_neon) then return false end
    return true
end

