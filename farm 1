-- COMPREHENSIVE BABY NEEDS DETECTION
function getBabyAilments()
    local ailments = {}
    local method = "None"
    
    -- Try to get client data
    local success, data = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
    end)
    
    if success and data then
        -- METHOD 1: Check baby_manager.ailments
        if data.baby_manager and data.baby_manager.ailments then
            for k, v in pairs(data.baby_manager.ailments) do
                ailments[k] = v
                method = "baby_manager.ailments"
            end
            if next(ailments) then return ailments, method end
        end
        
        -- METHOD 2: Check baby_manager.needs
        if data.baby_manager and data.baby_manager.needs then
            for k, v in pairs(data.baby_manager.needs) do
                ailments[k] = v
                method = "baby_manager.needs"
            end
            if next(ailments) then return ailments, method end
        end
        
        -- METHOD 3: Check baby_manager.active_ailments
        if data.baby_manager and data.baby_manager.active_ailments then
            for k, v in pairs(data.baby_manager.active_ailments) do
                ailments[k] = v
                method = "baby_manager.active_ailments"
            end
            if next(ailments) then return ailments, method end
        end
        
        -- METHOD 4: Check baby_status
        if data.baby_status then
            for k, v in pairs(data.baby_status) do
                if type(v) == "table" and v.active then
                    ailments[k] = v
                    method = "baby_status"
                elseif type(v) == "boolean" and v then
                    ailments[k] = v
                    method = "baby_status_bool"
                end
            end
            if next(ailments) then return ailments, method end
        end
        
        -- METHOD 5: Check player_data for baby fields
        for k, v in pairs(data) do
            if type(k) == "string" and k:lower():find("baby") then
                print("Found baby field:", k)
                if type(v) == "table" then
                    for k2, v2 in pairs(v) do
                        ailments[k2] = v2
                        method = "dynamic_field_"..k
                    end
                end
            end
        end
        if next(ailments) then return ailments, method end
    end
    
    -- METHOD 6: Check GUI elements
    if Player and Player.PlayerGui then
        -- Check BabyApp
        local babyGui = Player.PlayerGui:FindFirstChild("BabyApp")
        if babyGui then
            local needsFrame = babyGui:FindFirstChild("Frame") or babyGui:FindFirstChild("NeedsFrame")
            if needsFrame then
                for _, child in pairs(needsFrame:GetChildren()) do
                    if child:IsA("Frame") or child:IsA("ImageLabel") then
                        -- Look for need indicators
                        local needName = child:FindFirstChild("NeedName") or child:FindFirstChild("TextLabel")
                        if needName and needName:IsA("TextLabel") and needName.Text ~= "" then
                            ailments[needName.Text:lower()] = true
                            method = "GUI_BabyApp"
                        end
                    end
                end
            end
            if next(ailments) then return ailments, method end
        end
        
        -- Check any GUI with "need" in name
        for _, gui in pairs(Player.PlayerGui:GetChildren()) do
            if gui.Name:lower():find("need") or gui.Name:lower():find("baby") then
                for _, child in pairs(gui:GetDescendants()) do
                    if child:IsA("TextLabel") and child.Text and child.Text:lower():find("hungry") or child.Text:lower():find("sleep") or child.Text:lower():find("dirty") then
                        ailments[child.Text:lower()] = true
                        method = "GUI_text_"..gui.Name
                    end
                end
            end
        end
        if next(ailments) then return ailments, method end
    end
    
    -- METHOD 7: Check character attachments
    if Player.Character then
        for _, child in pairs(Player.Character:GetDescendants()) do
            if child:IsA("BillboardGui") then
                for _, text in pairs(child:GetDescendants()) do
                    if text:IsA("TextLabel") and text.Text and text.Text ~= "" then
                        ailments[text.Text:lower()] = true
                        method = "Character_Billboard"
                    end
                end
            end
        end
        if next(ailments) then return ailments, method end
    end
    
    -- METHOD 8: Check workspace for baby indicators
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name:lower():find("baby") and obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            -- Found a baby model, check its attributes
            local humanoid = obj:FindFirstChild("Humanoid")
            if humanoid then
                -- Look for needs in attributes
                local attrs = obj:GetAttributes()
                for k, v in pairs(attrs) do
                    if type(k) == "string" and (k:lower():find("need") or k:lower():find("ailment")) then
                        ailments[k] = v
                        method = "Workspace_Attributes"
                    end
                end
            end
        end
    end
    if next(ailments) then return ailments, method end
    
    return ailments, method
end

function getBabyFurniture(type)
    GoToHome()
    task.wait(2)
    
    if not workspace.HouseInteriors or not workspace.HouseInteriors.furniture then
        return nil
    end
    
    for i, v in pairs(workspace.HouseInteriors.furniture:GetChildren()) do
        if v:FindFirstChildWhichIsA("Model") then
            local Furniture = v:FindFirstChildWhichIsA("Model")
            local furnitureName = Furniture.Name:lower()
            
            if type == "crib" and (furnitureName:find("crib") or (furnitureName:find("bed") and furnitureName:find("baby"))) then
                print("Found crib: " .. v.Name)
                return v.Name
            elseif type == "shower" and (furnitureName:find("shower") or furnitureName:find("bath") or furnitureName:find("tub")) then
                print("Found shower: " .. v.Name)
                return v.Name
            elseif type == "highchair" and furnitureName:find("highchair") then
                print("Found highchair: " .. v.Name)
                return v.Name
            end
        end
    end
    return nil
end

