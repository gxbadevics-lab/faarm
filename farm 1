            floor.Name     = "LowestFloor"
            local tileSize = 2000
            local tiles    = math.ceil(350000 / tileSize)
            for x = -tiles/2, tiles/2 - 1 do
                for z = -tiles/2, tiles/2 - 1 do
                    local tile           = Instance.new("Part")
                    tile.Size            = Vector3.new(tileSize, 500, tileSize)
                    tile.Position        = Vector3.new(x*tileSize + tileSize/2, -400, z*tileSize + tileSize/2)
                    tile.Anchored        = true
                    tile.Material        = Enum.Material.Grass
                    tile.Color           = Color3.fromRGB(106, 127, 63)
