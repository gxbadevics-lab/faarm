local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Player = Players.LocalPlayer

-- Baby farm toggle
local babyFarm = true

-- Tasks that need different handling
local taskLocations = {
    pizza_party = "PizzaShop",
    salon = "Salon",
    school = "School",
    pool_party = "pool",
    camping = "campsite",
    beach_party = "beach",
    hot_spring = "hotspring"
}

-- Wait for game to load
repeat task.wait(1) until Player and Player.Character

-- Location function (simplified)
local Location = nil
for i, v in pairs(getgc()) do
    if type(v) == "function" and getfenv(v).script and getfenv(v).script.Name == "InteriorsM" then
        Location = v
        break
    end
end

function GoToPlace(place)
    if not Location then return false end
    pcall(Location, place, "MainDoor", {})
    return true
end

-- Baby functions
function becomeBaby()
    print("Becoming baby...")
    pcall(function()
        local args = {
            [1] = "Babies",
            [2] = {["dont_respawn"] = true, ["source_for_logging"] = "avatar_editor"}
        }
        ReplicatedStorage.API.TeamAPI.ChooseTeam:InvokeServer(unpack(args))
    end)
end

function isBaby()
    return Player.Team and Player.Team.Name == "Babies"
end

-- Simple UI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "BabyFarm"
screenGui.ResetOnSpawn = false
screenGui.Parent = Player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 250, 0, 150)
frame.Position = UDim2.new(0, 10, 0.5, -75)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.BackgroundTransparency = 0.2
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = frame

local status = Instance.new("TextLabel")
status.Size = UDim2.new(1, -10, 1, -10)
status.Position = UDim2.new(0, 5, 0, 5)
status.BackgroundTransparency = 1
status.Text = "Baby Farm: Starting..."
status.TextColor3 = Color3.fromRGB(255, 255, 255)
status.Font = Enum.Font.Gotham
status.TextSize = 14
status.TextWrapped = true
status.Parent = frame

-- Main loop
spawn(function()
    while babyFarm do
        pcall(function()
            if not isBaby() then
                status.Text = "Becoming baby..."
                becomeBaby()
                task.wait(5)
                return
            end
            
            -- Get current tasks from ailments
            local data = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
            local tasks = {}
            
            if data and data.ailments_manager and data.ailments_manager.ailments then
                for _, ailments in pairs(data.ailments_manager.ailments) do
                    for task, _ in pairs(ailments) do
                        tasks[task] = true
                    end
                end
            end
            
            -- Do each task
            for task in pairs(tasks) do
                status.Text = "Doing: " .. task
                print("Starting task:", task)
                
                -- Location-based tasks
                if task == "pizza_party" then
                    GoToPlace("PizzaShop")
                    task.wait(20)
                    GoToPlace("housing")
                    
                elseif task == "salon" then
                    GoToPlace("Salon")
                    task.wait(20)
                    GoToPlace("housing")
                    
                elseif task == "school" then
                    GoToPlace("School")
                    task.wait(20)
                    GoToPlace("housing")
                    
                elseif task == "pool_party" or task == "beach_party" then
                    GoToPlace("MainMap")
                    task.wait(10)
                    GoToPlace("housing")
                    
                elseif task == "camping" then
                    GoToPlace("MainMap")
                    task.wait(10)
                    GoToPlace("housing")
                    
                elseif task == "hot_spring" then
                    GoToPlace("MainMap")
                    task.wait(10)
                    GoToPlace("housing")
                    
                -- Food/drink tasks
                elseif task == "hungry" or task == "thirsty" then
                    -- Buy and use bottle
                    ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_bottle", {buy_count = 1})
                    task.wait(1)
                    
                    local foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food
                    for _, item in pairs(foods) do
                        if item.id == "baby_bottle" then
                            ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(item.unique, {use_sound_delay = true})
                            task.wait(1)
                            ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(item.unique, "START")
                            task.wait(4)
                            ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(item.unique, "END")
                            ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(item.unique)
                            break
                        end
                    end
                    
                elseif task == "sick" then
                    -- Buy and use medicine
                    ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_medicine", {buy_count = 1})
                    task.wait(1)
                    
                    local foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food
                    for _, item in pairs(foods) do
                        if item.id == "baby_medicine" then
                            ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(item.unique, {use_sound_delay = true})
                            task.wait(1)
                            ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(item.unique, "START")
                            task.wait(3)
                            ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(item.unique, "END")
                            ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(item.unique)
                            break
                        end
                    end
                    
                elseif task == "play" then
                    -- Use a toy
                    local toys = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.toys
                    for _, item in pairs(toys) do
                        ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(item.unique, {use_sound_delay = true})
                        task.wait(1)
                        ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(item.unique, "START")
                        task.wait(2)
                        ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(item.unique, "END")
                        ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(item.unique)
                        break
                    end
                    
                elseif task == "sleepy" or task == "dirty" or task == "toilet" or task == "bored" then
                    -- These need furniture at home
                    GoToPlace("housing")
                    task.wait(5) -- Just wait at home
                end
                
                -- Add progress for the task
                ReplicatedStorage.API.MonitorAPI.AddAdditive:FireServer(task, 100)
                task.wait(2)
            end
            
            task.wait(5)
        end)
        task.wait(1)
    end
end)

print("Baby Farm Started")
