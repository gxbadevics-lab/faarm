-- TRADE LICENSE: use new ClientData method, kick if just got it
---------------------------------------------------------------------
local ClientData = require(ReplicatedStorage.ClientModules.Core.ClientData)

local function hasTradeLicense()
    local ok, result = pcall(function()
        return ClientData.get_data()[Player.Name].settings.has_trade_license == true
    end)
    if ok then return result end
    -- fallback: check inventory for trade_license toy
    local ok2, toys = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.toys or {}
    end)
    if ok2 then
        for _, v in pairs(toys) do
            if v.id == "trade_license" then return true end
        end
    end
    return false
end

if not hasTradeLicense() then
    print("Getting Trade License automatically...")
    pcall(function()
        -- Mark NPC talked to
        ReplicatedStorage.API["SettingsAPI/SetBooleanFlag"]:FireServer("has_talked_to_trade_quest_npc", true)
        task.wait(0.5)
        -- Handle new-account tutorial if needed
        if tieneTutorial then
            task.wait(2)
            pcall(function()
                require(ReplicatedStorage.ClientModules.Game.Tutorial.LegacyTutorial).force_tutorial_completed()
                require(ReplicatedStorage.ClientModules.Game.Tutorial.LegacyTutorial).cancel_tutorial()
            end)
            task.wait(5)
        end
        -- Quiz loop until license confirmed
        local gotLicense = false
        local attempts   = 0
        while not gotLicense and attempts < 10 do
            attempts += 1
            -- Try new ClientData quiz answers first
            local answeredViaClientData = false
            pcall(function()
                local quiz = ClientData.get_data()[Player.Name].trade_license_quiz_manager.quiz
                ReplicatedStorage.API["TradeAPI/BeginQuiz"]:FireServer()
                task.wait(1)
                for _, qdata in pairs(quiz) do
                    ReplicatedStorage.API["TradeAPI/AnswerQuizQuestion"]:FireServer(qdata["answer"])
                    task.wait(0.8)
                end
                answeredViaClientData = true
            end)
            -- Fallback to hardcoded answers
            if not answeredViaClientData then
                ReplicatedStorage.API["TradeAPI/BeginQuiz"]:FireServer()
                task.wait(1)
                local answers = {"not safe", "safe", "not safe"}
                for _, answer in ipairs(answers) do
                    ReplicatedStorage.API["TradeAPI/AnswerQuizQuestion"]:FireServer(answer)
                    task.wait(0.8)
                end
            end
            ReplicatedStorage.API:FindFirstChild("TradeAPI/EndQuiz"):FireServer()
            task.wait(2)
            gotLicense = hasTradeLicense()
        end
        if gotLicense then
            print("Trade License acquired! Kicking to reload...")
            task.wait(1)
            Player:Kick("Trade License acquired — please rejoin to continue farming.")
        else
            print("Could not get trade license after "..attempts.." attempts. Continuing anyway.")
        end
    end)
else
    print("Trade License already owned — continuing.")
end

