local net = RS:WaitForChild("adoptme_new_net", 30)
local pickup, redeem

for _, child in ipairs(net:GetChildren()) do
	if child.Name:find("ChocolateRiverNet") and child:IsA("RemoteEvent") then
		if not pickup then
			pickup = child
		elseif tonumber(child.Name:match(":(%d+)$")) < tonumber(pickup.Name:match(":(%d+)$")) then
			redeem = pickup
			pickup = child
		else
			redeem = child
		end
	end
end

