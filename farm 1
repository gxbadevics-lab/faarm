local current_potion_type = potionType

function FGPet(petID)
    if CheckFG(petID) then
        print("Already full grown:", petID)
        return
    end
    pcall(function()
        RS:WaitForChild("API"):WaitForChild("ToolAPI/Equip"):InvokeServer(petID)
        repeat task.wait() until ClientData.get_data()[Player.Name].pet_char_wrappers[1]

        while task.wait() do
            local wrapper = ClientData.get_data()[Player.Name].pet_char_wrappers[1]
            if not wrapper or wrapper.pet_progression["age"] >= 6 then break end

            local potionId    = nil
            local potionTable = {}
            local potionCount = GetMultiPotCount(petID, current_potion_type)

            for l, o in pairs(ClientData.get_data()[Player.Name].inventory.food) do
                if o.id == current_potion_type then
                    if not potionId then
                        potionId = l
                    else
                        if #potionTable + 1 < potionCount then
                            table.insert(potionTable, l)
                        end
                    end
                end
            end

            if not potionId then
                if current_potion_type == "pet_age_potion" then
                    current_potion_type = "tiny_pet_age_potion"
                    return FGPet(petID)
                else
                    current_potion_type = "pet_age_potion"
                    print("Out of potions!")
                    break
                end
            end

            if CheckPetEquipID(petID) then
                task.wait(1)
                local ok, _ = pcall(function()
                    RouterClient.get("PetObjectAPI/CreatePetObject"):InvokeServer(
                        "__Enum_PetObjectCreatorType_2",
                        {pet_unique = petID, unique_id = potionId, additional_consume_uniques = potionTable}
                    )
                end)
                if ok then
                    repeat task.wait()
                        pcall(function()
                            RouterClient.get("PetAPI/ConsumeFoodObject"):FireServer(
                                workspace.PetObjects:FindFirstChildWhichIsA("Model"), petID)
                        end)
                    until not (workspace.PetObjects:FindFirstChild("AgePotion") or workspace.PetObjects:FindFirstChild("TinyAgePotion"))
                end
            else
                break
            end
        end
        print("FG done:", petID)
    end)
end

local function getFullgrownPets(forMega)
    local result = {}
    local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
    if not ok then return result end
    for _, v in pairs(pets) do
        local match = false
        if forMega then
            match = v.properties.age == 6 and v.properties.neon and not v.properties.mega_neon
        else
            match = v.properties.age == 6 and not v.properties.neon and not v.properties.mega_neon
        end
        if match then
            if not result[v.id] then result[v.id] = {count=0, unique={}} end
            result[v.id].count += 1
            table.insert(result[v.id].unique, v.unique)
            if result[v.id].count >= 4 then break end
        end
    end
    return result
end

function MakeMega(forMega)
    repeat
        local fusionReady = {}
        local groups = getFullgrownPets(forMega)
        for _, g in pairs(groups) do
            if g.count >= 4 then
                fusionReady = {g.unique[1], g.unique[2], g.unique[3], g.unique[4]}
                break
            end
        end
        if #fusionReady >= 4 then
            pcall(function()
                RS.API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer({unpack(fusionReady)})
            end)
            task.wait(0.5)
        end
    until #fusionReady < 4
end

