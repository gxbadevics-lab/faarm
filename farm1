-- Get baby tasks (from ailments that are NOT for pets)
function getBabyTasks()
    local babyTasks = {}
    local success, data = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
    end)
    
    if success and data and data.ailments_manager and data.ailments_manager.ailments then
        local allAilments = data.ailments_manager.ailments
        
        -- Look for the baby's ailments (usually stored under a specific ID)
        for entityId, ailments in pairs(allAilments) do
            -- Skip if this looks like a pet ID (usually longer strings)
            if not tostring(entityId):find("%-") and not tostring(entityId):find("_") then
                for taskName, taskData in pairs(ailments) do
                    babyTasks[taskName] = taskData
                    print("Baby task detected:", taskName)
                end
            end
        end
    end
    
    return babyTasks
end

-- Find baby furniture
function getBabyFurniture()
    GoToHome()
    task.wait(2)
    
    babyCrib = nil
    babyShower = nil
    babyHighChair = nil
    babyPlayMat = nil
    
    if not workspace.HouseInteriors or not workspace.HouseInteriors.furniture then
        return
    end
    
    for i, v in pairs(workspace.HouseInteriors.furniture:GetChildren()) do
        if v:FindFirstChildWhichIsA("Model") then
            local Furniture = v:FindFirstChildWhichIsA("Model")
            local furnitureName = Furniture.Name:lower()
            
            if furnitureName:find("crib") or (furnitureName:find("bed") and furnitureName:find("baby")) then
                babyCrib = v.Name
                print("Found crib")
            elseif furnitureName:find("shower") or furnitureName:find("bath") or furnitureName:find("tub") then
                babyShower = v.Name
                print("Found shower")
            elseif furnitureName:find("highchair") or (furnitureName:find("chair") and furnitureName:find("baby")) then
                babyHighChair = v.Name
                print("Found highchair")
            elseif furnitureName:find("play") and (furnitureName:find("mat") or furnitureName:find("gym")) then
                babyPlayMat = v.Name
                print("Found play mat")
            end
        end
    end
end

-- Handle baby task
function handleBabyTask(taskName)
    print("Starting baby task:", taskName)
    
    -- Add progress first
    pcall(function()
        ReplicatedStorage.API.MonitorAPI.AddAdditive:FireServer(taskName, 100)
    end)
    
    -- SLEEPY - Use crib
    if taskName == "sleepy" and babyCrib then
        SueloTemporal()
        GoToHome()
        task.wait(1)
        
        local furnitureId = babyCrib:sub(#Player.Name + 13)
        pcall(function()
            local args = {
                [1] = Player,
                [2] = furnitureId,
                [3] = "UseBlock",
                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                [5] = Player.Character
            }
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        task.wait(15)
    
    -- DIRTY - Use shower
    elseif taskName == "dirty" and babyShower then
        SueloTemporal()
        GoToHome()
        task.wait(1)
        
        local furnitureId = babyShower:sub(#Player.Name + 13)
        pcall(function()
            local args = {
                [1] = Player,
                [2] = furnitureId,
                [3] = "UseBlock",
                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                [5] = Player.Character
            }
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        task.wait(15)
    
    -- BORED - Use play mat
    elseif taskName == "bored" and babyPlayMat then
        SueloTemporal()
        GoToHome()
        task.wait(1)
        
        local furnitureId = babyPlayMat:sub(#Player.Name + 13)
        pcall(function()
            local args = {
                [1] = Player,
                [2] = furnitureId,
                [3] = "UseBlock",
                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                [5] = Player.Character
            }
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        task.wait(15)
    
    -- HUNGRY/THIRSTY - Use bottle
    elseif taskName == "hungry" or taskName == "thirsty" then
        -- Buy bottle if needed
        local Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
        local bottle = nil
        
        for i, v in pairs(Foods) do
            if v.id == "baby_bottle" then
                bottle = v.unique
                break
            end
        end
        
        if not bottle then
            pcall(function()
                ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_bottle", {["buy_count"] = 1})
            end)
            task.wait(1)
        end
        
        -- Use bottle
        if bottle then
            pcall(function()
                ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(bottle, {use_sound_delay = true, equip_as_last = false})
            end)
            task.wait(1)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(bottle, "START")
            end)
            task.wait(4)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(bottle, "END")
                ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(bottle)
            end)
        end
        task.wait(1)
    
    -- SICK - Use medicine
    elseif taskName == "sick" then
        local Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
        local medicine = nil
        
        for i, v in pairs(Foods) do
            if v.id == "baby_medicine" then
                medicine = v.unique
                break
            end
        end
        
        if not medicine then
            pcall(function()
                ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_medicine", {["buy_count"] = 1})
            end)
            task.wait(1)
        end
        
        if medicine then
            pcall(function()
                ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(medicine, {use_sound_delay = true, equip_as_last = false})
            end)
            task.wait(1)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(medicine, "START")
            end)
            task.wait(3)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(medicine, "END")
                ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(medicine)
            end)
        end
        task.wait(1)
    
    -- PLAY - Use toy
    elseif taskName == "play" then
        local Toys = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.toys or {}
        for _, v in pairs(Toys) do
            pcall(function()
                ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(v.unique, {use_sound_delay = true, equip_as_last = false})
            end)
            task.wait(1)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(v.unique, "START")
            end)
            task.wait(2)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(v.unique, "END")
                ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(v.unique)
            end)
            break
        end
        task.wait(1)
    
    -- Location-based tasks
    elseif taskName == "pizza_party" then
        SueloTemporal()
        GoToStore("PizzaShop")
        task.wait(20)
        GoToHome()
        
    elseif taskName == "salon" then
        SueloTemporal()
        GoToStore("Salon")
        task.wait(20)
        GoToHome()
        
    elseif taskName == "school" then
        SueloTemporal()
        GoToStore("School")
        task.wait(20)
        GoToHome()
        
    elseif taskName == "pool_party" or taskName == "beach_party" then
        SueloTemporal()
        GoToMainMap()
        task.wait(20)
        GoToHome()
        
    elseif taskName == "camping" then
        SueloTemporal()
        GoToMainMap()
        task.wait(20)
        GoToHome()
        
    elseif taskName == "hot_spring" then
        SueloTemporal()
        GoToMainMap()
        task.wait(20)
        GoToHome()
        
    elseif taskName == "toilet" then
        -- Just wait at home
        SueloTemporal()
        GoToHome()
        task.wait(10)
    end
    
    print("Task completed:", taskName)
end

