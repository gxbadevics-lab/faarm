                        if fusionOn then MakeMega(false) MakeMega(true) end
                        if GetPotions(current_potion_type) == 0 then
                            print("Out of potions for", petName)
                            break
                        end
                        task.wait(2)
                    end
                end

                if neonGoal > 0 then
                    local attempts = 0
                    while attempts < 15 do
                        attempts += 1
                        local curNeon   = CountPetsByName(petName, "neon")
                        print(petName, "neons:", curNeon, "/", neonGoal)
                        if curNeon >= neonGoal then print("Neon goal reached for", petName) break end

                        local curNormal = CountPetsByName(petName, "normal")
                        local needed    = (neonGoal - curNeon) * 4
                        local counter   = math.min(needed, curNormal - (curNormal % 4))

                        if counter <= 0 then
                            print("Not enough", petName, "normals to make neon (need 4)")
                            break
                        end
                        print("Need to age", counter, petName, "normals for neon")

                        local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id) == petName and not v.properties.neon and not v.properties.mega_neon then
                                    if GetPotions(current_potion_type) > 0 then
                                        FGPet(uid)
                                        counter -= 1
                                    else break end
                                end
                                task.wait()
                            end
                        end

                        if fusionOn then MakeMega(false) end
                        if GetPotions(current_potion_type) == 0 then
                            print("Out of potions for", petName)
                            break
                        end
                        task.wait(2)
                    end
                end

                if normalGoal > 0 then
                    local attempts = 0
                    while attempts < 15 do
                        attempts += 1
                        local fullNormal = 0
                        local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for _, v in pairs(pets) do
                                if findPetDisplayName(v.id) == petName
                                    and not v.properties.neon and not v.properties.mega_neon
                                    and v.properties.age == 6 then
                                    fullNormal += 1
                                end
                            end
                        end
                        print(petName, "full-grown normals:", fullNormal, "/", normalGoal)
                        if fullNormal >= normalGoal then print("Normal goal reached for", petName) break end

                        local counter = normalGoal - fullNormal
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id) == petName
                                    and not v.properties.neon and not v.properties.mega_neon
                                    and v.properties.age < 6 then
                                    if GetPotions(current_potion_type) > 0 then
                                        FGPet(uid)
                                        counter -= 1
                                    else break end
                                end
                                task.wait()
                            end
                        end

                        if GetPotions(current_potion_type) == 0 then
                            print("Out of potions for", petName)
                            break
                        end
                        task.wait(2)
                    end
                end

                print("Done with:", petName)
                task.wait(3)
            end
        end)
        task.wait(120)
    end
end)

