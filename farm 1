local function disableEffects(object)
    if object:IsA("Part") or object:IsA("UnionOperation") or object:IsA("MeshPart") or object:IsA("CornerWedgePart") or object:IsA("TrussPart") then
        object.Material = Enum.Material.SmoothPlastic
        object.Reflectance = 0
    elseif object:IsA("Decal") then
        object.Transparency = 0
    elseif object:IsA("ParticleEmitter") or object:IsA("Trail") then
        object.Lifetime = NumberRange.new(0)
    elseif object:IsA("Explosion") then
        object.BlastPressure = 0
        object.BlastRadius = 0
    elseif object:IsA("Smoke") or object:IsA("Fire") or object:IsA("SpotLight") or object:IsA("Sparkles") then
        object.Enabled = false
    elseif object:IsA("MeshPart") then
        object.Material = Enum.Material.SmoothPlastic
        object.Reflectance = 0
        object.TextureID = 10385902758728957
    end
end
 
local function disableVisualEffects(effect)
    if effect:IsA("BlurEffect") or effect:IsA("SunRaysEffect") or effect:IsA("ColorCorrectionEffect") or effect:IsA("BloomEffect") or effect:IsA("DepthOfFieldEffect") then
        effect.Enabled = false
    end
end
 
