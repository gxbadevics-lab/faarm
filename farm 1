local Location
for i, v in pairs(getgc()) do
    if type(v) == "function" then
        if getfenv(v).script == ReplicatedStorage.ClientModules.Core.InteriorsM.InteriorsM then
            if table.find(getconstants(v), "LocationAPI/SetLocation") then
                Location = v
                break
            end
        end
    end
end

local function SetLocation(a, b, c)
    local k = get_thread_identity and get_thread_identity() or 2
    set_thread_identity and set_thread_identity(2) or (syn and syn.set_thread_identity(2))
    wait()
    Location(a, b, c)
    set_thread_identity and set_thread_identity(k) or (syn and syn.set_thread_identity(k))
    wait()
end

function GoToHome()
    if not Location then return false end
    SetLocation("housing", "MainDoor", {["house_owner"] = Player})
    return true
end

function createLabel(frame, position, text)
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(0, 300, 0, 50)
    textLabel.Position = UDim2.new(0.5, 0, position, 0)
    textLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    textLabel.TextScaled = true
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.Text = text
    textLabel.BackgroundTransparency = 1
    textLabel.ZIndex = 11
    textLabel.Parent = frame
    return textLabel
end

-- Baby farm functions
function isPlayerBaby()
    local playerTeam = Player.Team
    if playerTeam and playerTeam.Name == "Babies" then
        return true
    end
    return false
end

function becomeBaby()
    print("Attempting to become baby...")
    local success = pcall(function()
        ReplicatedStorage.API:FindFirstChild("AdoptAPI/BecomeBaby"):FireServer()
    end)
    
    if not success then
        pcall(function()
            ReplicatedStorage.API["TeamAPI/ChooseTeam"]:InvokeServer("Babies", {
                ["dont_send_back_home"] = true, 
                ["source_for_logging"] = "avatar_editor"
            })
        end)
    end
end

function becomeParent()
    pcall(function()
        ReplicatedStorage.API["TeamAPI/ChooseTeam"]:InvokeServer("Parents", {
            ["dont_send_back_home"] = true, 
            ["source_for_logging"] = "avatar_editor"
        })
    end)
end

function getBabyAilments()
    local success, data = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
    end)
    
    if success and data and data.baby_manager then
        return data.baby_manager.ailments or {}
    end
    return {}
end

function getBabyFurniture(type)
    GoToHome()
    task.wait(2)
    
    for i, v in pairs(workspace.HouseInteriors.furniture:GetChildren()) do
        if v:FindFirstChildWhichIsA("Model") then
            local Furniture = v:FindFirstChildWhichIsA("Model")
            local furnitureName = Furniture.Name:lower()
            
            if type == "crib" and (furnitureName:find("crib") or (furnitureName:find("bed") and furnitureName:find("baby"))) then
                print("Found crib: " .. v.Name)
                return v.Name
            elseif type == "shower" and (furnitureName:find("shower") or furnitureName:find("bath") or furnitureName:find("tub")) then
                print("Found shower: " .. v.Name)
                return v.Name
            elseif type == "highchair" and furnitureName:find("highchair") then
                print("Found highchair: " .. v.Name)
                return v.Name
            end
        end
    end
    return nil
end

-- Main baby farm loop
function startBabyFarm()
    spawn(function()
        while babyFarm do
            -- Check if we're a baby
            if not isPlayerBaby() then
                if infoBabyStatus then
                    infoBabyStatus.Text = "Status: Becoming Baby..."
                end
                becomeBaby()
                task.wait(5)
            else
                if infoBabyStatus then
                    infoBabyStatus.Text = "Status: Baby Mode Active"
                end
                
                -- Get baby needs
                local babyAilments = getBabyAilments()
                
                -- Find furniture if needed
                if not babyCrib then
                    babyCrib = getBabyFurniture("crib")
                end
                if not babyShower then
                    babyShower = getBabyFurniture("shower")
                end
                if not babyHighChair then
                    babyHighChair = getBabyFurniture("highchair")
                end
                
                -- Handle baby needs
                if babyAilments and not isBabyDoingTask then
                    -- Sleepy
                    if babyAilments.sleepy and babyCrib then
                        print("Baby is sleepy - using crib")
                        isBabyDoingTask = "sleepy"
                        if infoBabyStatus then
                            infoBabyStatus.Text = "Status: Putting to Sleep"
                        end
                        
                        GoToHome()
                        task.wait(1)
                        
                        local args = {
                            [1] = Player,
                            [2] = babyCrib:sub(#Player.Name + 13),
                            [3] = "UseBlock",
                            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                            [5] = Player.Character
                        }
                        
                        pcall(function()
                            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
                        end)
                        
                        task.wait(15)
                        isBabyDoingTask = false
                        
                    -- Dirty
                    elseif babyAilments.dirty and babyShower then
                        print("Baby is dirty - using shower")
                        isBabyDoingTask = "dirty"
                        if infoBabyStatus then
                            infoBabyStatus.Text = "Status: Bathing"
                        end
                        
                        GoToHome()
                        task.wait(1)
                        
                        local args = {
                            [1] = Player,
                            [2] = babyShower:sub(#Player.Name + 13),
                            [3] = "UseBlock",
                            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                            [5] = Player.Character
                        }
                        
                        pcall(function()
                            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
                        end)
                        
                        task.wait(15)
                        isBabyDoingTask = false
                        
                    -- Hungry/Thirsty
                    elseif (babyAilments.hungry or babyAilments.thirsty) and babyHighChair then
                        print("Baby needs food/drink - using highchair")
                        isBabyDoingTask = "feeding"
                        if infoBabyStatus then
                            infoBabyStatus.Text = "Status: Feeding"
                        end
                        
                        GoToHome()
                        task.wait(1)
                        
                        -- Put in high chair
                        local chairArgs = {
                            [1] = Player,
                            [2] = babyHighChair:sub(#Player.Name + 13),
                            [3] = "Seat1",
                            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                            [5] = Player.Character
                        }
                        
                        pcall(function()
                            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(chairArgs))
                        end)
                        
                        task.wait(2)
                        
                        -- Get baby bottle
                        local Foods = {}
                        pcall(function()
                            Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
                        end)
                        
                        local babyBottle = nil
                        for i, v in pairs(Foods) do
                            if v.id == "baby_bottle" then
                                babyBottle = v.unique
                                break
                            end
                        end
                        
                        if not babyBottle then
                            pcall(function()
                                ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_bottle", {["buy_count"] = 1})
                            end)
                            task.wait(2)
                            
                            pcall(function()
                                Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
                            end)
                            for i, v in pairs(Foods) do
                                if v.id == "baby_bottle" then
                                    babyBottle = v.unique
                                    break
                                end
                            end
                        end
                        
                        if babyBottle then
                            pcall(function()
                                ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(babyBottle, {
                                    use_sound_delay = true,
                                    equip_as_last = false
                                })
                            end)
                            
                            task.wait(1)
                            
                            pcall(function()
                                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(babyBottle, "START")
                            end)
                            
                            task.wait(4)
                            
                            pcall(function()
                                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(babyBottle, "END")
                                ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(babyBottle)
                            end)
                        end
                        
                        task.wait(5)
                        isBabyDoingTask = false
                    end
                end
            end
            
            task.wait(2)
        end
    end)
end

