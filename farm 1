-- Pet farming functions
local Pet = nil
local PetID = nil

function getPetToFarm()
    local Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}
    
    -- FIRST: If autoEggFarm is enabled, look for eggs that need growing
    if autoEggFarm then
        for k,v in pairs(Pets) do
            if v['id'] ~= "practice_dog" and isEgg(v['id']) and v['properties']['age'] < 6 then
                print("Found egg to grow naturally:", v['id'], "age:", v['properties']['age'])
                return v
            end
        end
    end
    
    -- THEN: Look for neons
    local maxAge = 0
    local newPet = nil
    for k,v in pairs(Pets) do
        if v['id'] ~= "practice_dog" then
            if v['properties']['age'] > maxAge and v['properties']['age'] < 6 and v['properties']['neon'] then
                maxAge = v['properties']['age']
                newPet = v
            end
        end
    end
    
    -- THEN: Any non-full-grown pet (including eggs if autoEggFarm is on)
    if not newPet then
        maxAge = 0
        for k,v in pairs(Pets) do
            if v['id'] ~= "practice_dog" then
                -- Include eggs if autoEggFarm is on
                if autoEggFarm and isEgg(v['id']) and v['properties']['age'] < 6 then
                    if v['properties']['age'] > maxAge then
                        maxAge = v['properties']['age']
                        newPet = v
                    end
                elseif not isEgg(v['id']) and v['properties']['age'] < 6 then
                    if v['properties']['age'] > maxAge then
                        maxAge = v['properties']['age']
                        newPet = v
                    end
                end
            end
        end
    end
    
    return newPet
end

function changePetTo(pet)
    if pet and pet['unique'] then
        PetID = pet['unique']
        ReplicatedStorage.API["ToolAPI/Unequip"]:InvokeServer(PetID)
        ReplicatedStorage.API["ToolAPI/Equip"]:InvokeServer(PetID)
        Pet = nil
        local timeTrying = 0
        while not Pet do
            Pet = getPet()
            task.wait(0.1)
            timeTrying += 0.1
            if timeTrying >= 5 then break end
        end
    end
end

function checkIfINeedToChange()
    local petToChange = nil
    local needToChange = false
    local Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}
    
    -- Auto-buy eggs if no growing pets and autoEggFarm is enabled
    if autoEggFarm then
        spawn(function()
            local hayNoFullGrown = false
            for k,v in pairs(Pets) do
                -- Include eggs in the check
                if v['id'] ~= "practice_dog" and v['properties']['age'] < 6 then
                    hayNoFullGrown = true
                    break
                end
            end
            if not hayNoFullGrown then
                print("No growing pets found - buying egg:", eggToBuy)
                ReplicatedStorage.API:FindFirstChild("ShopAPI/BuyItem"):InvokeServer("pets", eggToBuy, {["buy_count"]=1})
                Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}
            end
        end)
    end
    
    if not Pet or not PetID then 
        needToChange = true 
        petToChange = getPetToFarm() 
    end
    
    if Pet and PetID then
        local Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}
        if Pets[tostring(PetID)] and Pets[tostring(PetID)]["properties"]["age"] == 6 then
            needToChange = true
            petToChange = getPetToFarm()
        end
    end
    
    if petToChange then
        if not PetID or PetID ~= petToChange['unique'] then
            changePetTo(petToChange)
        end
    end
    
    if not Pet or not PetID or (needToChange and not petToChange) then
        local Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}
        for k,v in pairs(Pets) do
            if v['id'] ~= "practice_dog" then
                petToChange = v
                break
            end
        end
        if petToChange then
            changePetTo(petToChange)
        end
    end
    print(Pet, PetID)
end

function cuantasPets(pets)
    local numero = 0
    for k,v in pairs(pets) do
        if v['id'] ~= "practice_dog" then
            numero = numero + 1
        end
