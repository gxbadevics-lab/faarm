-- Main baby farm loop
function startBabyFarm(uiElements)
    spawn(function()
        local startTime = os.time()
        
        while _G.autofarm do
            pcall(function()
                if babyFarmEnabled then
                    updatePetID()
                    
                    if not isPlayerBaby() then
                        if uiElements and uiElements.statusLabel then
                            uiElements.statusLabel.Text = "Status: Becoming Baby..."
                        end
                        becomeBaby()
                        task.wait(5)
                    else
                        if uiElements and uiElements.statusLabel then
                            uiElements.statusLabel.Text = "Status: Baby Mode Active"
                        end
                        
                        local babyTasks = getBabyAilments()
                        
                        -- Find furniture if needed
                        if not babyCrib or not babyShower or not babyHighChair then
                            getBabyFurniture()
                        end
                        
                        -- Update furniture status
                        if uiElements and uiElements.furnitureLabel then
                            uiElements.furnitureLabel.Text = string.format(
                                "Furniture:\nCrib: %s | Shower: %s\nChair: %s | Play Mat: %s",
                                babyCrib and "✓" or "?",
                                babyShower and "✓" or "?",
                                babyHighChair and "✓" or "?",
                                babyPlayMat and "✓" or "?"
                            )
                        end
                        
                        -- Update time
                        if uiElements and uiElements.timeLabel then
                            local elapsedTime = os.difftime(os.time(), startTime)
                            local elapsedMinutes = math.floor(elapsedTime / 60)
                            local elapsedHours = math.floor(elapsedMinutes / 60)
                            uiElements.timeLabel.Text = "Time: " .. elapsedHours .. "h " .. elapsedMinutes % 60 .. "min"
                        end
                        
                        -- Handle baby tasks
                        if babyTasks and next(babyTasks) and not isBabyDoingTask then
                            for taskName, _ in pairs(babyTasks) do
                                isBabyDoingTask = true
                                handleBabyTask(taskName, uiElements)
                                isBabyDoingTask = false
                                break
                            end
                        end
                    end
                else
                    if isPlayerBaby() then
                        becomeParent()
                    end
                    task.wait(1)
                end
            end)
            task.wait(2)
        end
    end)
end

