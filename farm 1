local current_potion_type = "pet_age_potion"

function FGPet(petID)
    if CheckFG(petID) then
        print("Already full grown:", petID)
        return
    end
    
    -- Make sure pet is equipped
    pcall(function()
        RS:WaitForChild("API"):WaitForChild("ToolAPI/Equip"):InvokeServer(petID)
    end)
    task.wait(1)
    
    -- Use potions until full grown
    local maxAttempts = 10
    local attempts = 0
    
    while attempts < maxAttempts do
        attempts = attempts + 1
        
        -- Check if already full grown
        if CheckFG(petID) then
            print("Pet is now full grown")
            break
        end
        
        -- Find potion
        local potionId = nil
        for l, o in pairs(ClientData.get_data()[Player.Name].inventory.food) do
            if o.id == current_potion_type then
                potionId = l
                break
            end
        end
        
        if not potionId then
            -- Try tiny potion
            if current_potion_type == "pet_age_potion" then
                current_potion_type = "tiny_pet_age_potion"
                print("Switching to tiny potions")
                -- Try again with tiny potion
                for l, o in pairs(ClientData.get_data()[Player.Name].inventory.food) do
                    if o.id == current_potion_type then
                        potionId = l
                        break
                    end
                end
            end
        end
        
        if not potionId then
            print("No potions available")
            break
        end
        
        -- Use potion
        pcall(function()
            RouterClient.get("PetObjectAPI/CreatePetObject"):InvokeServer(
                "__Enum_PetObjectCreatorType_2",
                {pet_unique = petID, unique_id = potionId, additional_consume_uniques = {}}
            )
            task.wait(1)
            
            -- Find and consume the potion object
            for _, obj in pairs(workspace.PetObjects:GetChildren()) do
                if obj:IsA("Model") and obj:FindFirstChild("OwnerPlayer") then
                    local owner = obj:FindFirstChild("OwnerPlayer")
                    if owner and owner.Value == Player then
                        RouterClient.get("PetAPI/ConsumeFoodObject"):FireServer(obj, petID)
                        break
                    end
                end
            end
        end)
        
        task.wait(2)
    end
    
    print("FGPet completed for:", petID)
end

