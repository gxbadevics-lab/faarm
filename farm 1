                            print(petName, "megas:", curMega, "/", megaGoal)
                            if curMega >= megaGoal then print("Mega goal reached for", petName) break end

                            local curNeon   = CountPetsByName(petName, "neon")
                            local curNormal = CountPetsByName(petName, "normal")
                            local total     = (curNeon * 4) + curNormal
                            local needed    = (megaGoal - curMega) * 16
                            local counter   = math.min(needed, total - (total % 16))

                            if counter <= 0 then
                                print("Not enough", petName, "to make mega (need 16 normals worth)")
                                break
                            end
                            print("Need to age", counter, petName, "pets for mega")

                            -- age neons first (each neon = 4 normals)
                            local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                            if ok then
                                for uid, v in pairs(pets) do
                                    if counter <= 0 then break end
                                    if findPetDisplayName(v.id) == petName and v.properties.neon and not v.properties.mega_neon then
                                        if GetPotions(current_potion_type) > 0 then
                                            FGPet(uid)
                                            counter -= 4
                                        else break end
                                    end
                                    task.wait()
                                end
                            end

                            -- age normals
                            ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                            if ok then
                                for uid, v in pairs(pets) do
                                    if counter <= 0 then break end
                                    if findPetDisplayName(v.id) == petName and not v.properties.neon and not v.properties.mega_neon then
                                        if GetPotions(current_potion_type) > 0 then
                                            FGPet(uid)
                                            counter -= 1
                                        else break end
                                    end
                                    task.wait()
                                end
                            end

                            if fusionOn then MakeMega(false) MakeMega(true) end
                            if GetPotions(current_potion_type) == 0 then
                                print("Out of potions for", petName)
                                break
                            end
                            task.wait(2)
                        end
                    end

                    -- NEON GOAL
                    if neonGoal > 0 then
                        local attempts = 0
                        while attempts < 15 do
                            attempts += 1
                            local curNeon   = CountPetsByName(petName, "neon")
                            print(petName, "neons:", curNeon, "/", neonGoal)
                            if curNeon >= neonGoal then print("Neon goal reached for", petName) break end

                            local curNormal = CountPetsByName(petName, "normal")
                            local needed    = (neonGoal - curNeon) * 4
                            local counter   = math.min(needed, curNormal - (curNormal % 4))

                            if counter <= 0 then
                                print("Not enough", petName, "normals to make neon (need 4)")
                                break
                            end
                            print("Need to age", counter, petName, "normals for neon")

                            local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                            if ok then
                                for uid, v in pairs(pets) do
                                    if counter <= 0 then break end
                                    if findPetDisplayName(v.id) == petName and not v.properties.neon and not v.properties.mega_neon then
                                        if GetPotions(current_potion_type) > 0 then
                                            FGPet(uid)
                                            counter -= 1
                                        else break end
                                    end
                                    task.wait()
                                end
                            end

                            if fusionOn then MakeMega(false) end
                            if GetPotions(current_potion_type) == 0 then
                                print("Out of potions for", petName)
                                break
                            end
                            task.wait(2)
                        end
                    end

                    -- NORMAL GOAL
                    if normalGoal > 0 then
                        local attempts = 0
                        while attempts < 15 do
                            attempts += 1
                            -- count only full-grown normals
                            local fullNormal = 0
                            local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                            if ok then
                                for _, v in pairs(pets) do
                                    if findPetDisplayName(v.id) == petName
                                        and not v.properties.neon and not v.properties.mega_neon
                                        and v.properties.age == 6 then
                                        fullNormal += 1
                                    end
                                end
                            end
                            print(petName, "full-grown normals:", fullNormal, "/", normalGoal)
                            if fullNormal >= normalGoal then print("Normal goal reached for", petName) break end

                            local counter = normalGoal - fullNormal
                            if ok then
                                for uid, v in pairs(pets) do
                                    if counter <= 0 then break end
                                    if findPetDisplayName(v.id) == petName
                                        and not v.properties.neon and not v.properties.mega_neon
                                        and v.properties.age < 6 then
                                        if GetPotions(current_potion_type) > 0 then
                                            FGPet(uid)
                                            counter -= 1
                                        else break end
                                    end
                                    task.wait()
                                end
                            end

                            if GetPotions(current_potion_type) == 0 then
                                print("Out of potions for", petName)
                                break
                            end
                            task.wait(2)
                        end
                    end

                    print("Done with:", petName)
                    task.wait(3)
                end
            end)
            -- run again every 2 minutes in case new pets arrived
            task.wait(120)
        end
    end)
end

