-- MODIFIED: Get best pet to farm - eggs are now treated equally
function getPetToFarm()
    if not ClientData then return nil end
    local ok, Pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets or {} end)
    if not ok then return nil end
    
    -- First: Find unhatched eggs (age 0 eggs)
    for _, v in pairs(Pets) do
        if v.id ~= "practice_dog" and isEgg(v.id) and v.properties.age == 0 then
            print("Found unhatched egg to grow:", v.id)
            return v
        end
    end
    
    -- Second: Find non-full grown pets (including eggs that have started growing)
    local bestPet = nil
    local bestAge = -1
    
    for _, v in pairs(Pets) do
        if v.id ~= "practice_dog" and not (isEgg(v.id) and v.properties.age == 0) and v.properties.age < 6 then
            if v.properties.age > bestAge then
                bestAge = v.properties.age
                bestPet = v
            end
        end
    end
    
    if bestPet then
        return bestPet
    end
    
    -- Third: Any pet (including full grown)
    for _, v in pairs(Pets) do
        if v.id ~= "practice_dog" then
            return v
        end
    end
    
    return nil
end

-- Change pet
function changePetTo(pet)
    if not (pet and pet.unique) then return end
    
    PetID = pet.unique
    pcall(function() RS.API.ToolAPI.Unequip:InvokeServer(PetID) end)
    task.wait(0.5)
    pcall(function() RS.API.ToolAPI.Equip:InvokeServer(PetID) end)
    
    Pet = nil
    local timeout = 0
    while not Pet and timeout < 5 do
        Pet = getPet()
        task.wait(0.2)
        timeout = timeout + 0.2
    end
    
    local petType = isEgg(pet.id) and "EGG" or "PET"
    print("Changed to", petType, ":", pet.id, "Age:", pet.properties.age)
end

