function getAilments()
    local ok, ailments = pcall(function()
        return ClientData.get_data()[Player.Name].ailments_manager.ailments or {}
    end)
    if ok and PetID and ailments[PetID] then return ailments[PetID] end
end

function getPetToFarm()
    local ok, Pets = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets or {}
    end)
    if not ok then return nil end
    local maxAge, newPet = 0, nil
    -- prefer neons in progress
    for _, v in pairs(Pets) do
        if v["id"] ~= "practice_dog" and v["properties"]["age"] > maxAge
            and v["properties"]["age"] < 6 and v["properties"]["neon"] then
            maxAge  = v["properties"]["age"]
            newPet  = v
        end
    end
    if not newPet then
        maxAge = 0
        for _, v in pairs(Pets) do
            if v["id"] ~= "practice_dog" and v["properties"]["age"] > maxAge
                and v["properties"]["age"] < 6 then
                maxAge = v["properties"]["age"]
                newPet = v
            end
        end
    end
    return newPet
end

function changePetTo(pet)
    if not (pet and pet["unique"]) then return end
    PetID = pet["unique"]
    pcall(function() ReplicatedStorage.API["ToolAPI/Unequip"]:InvokeServer(PetID) end)
    pcall(function() ReplicatedStorage.API["ToolAPI/Equip"]:InvokeServer(PetID) end)
    Pet = nil
    local t = 0
    while not Pet and t < 5 do
        Pet = getPet()
        task.wait(0.1)
        t += 0.1
    end
end

function checkIfINeedToChange()
    local ok, Pets = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets or {}
    end)
    if not ok then return end

    -- egg farm: if no growable pets, buy a new egg
    if autoEggFarm then
        spawn(function()
            local hayNoFullGrown = false
            for _, v in pairs(Pets) do
                if v["id"] ~= "practice_dog" and v["properties"]["age"] < 6 then
                    hayNoFullGrown = true
                    break
                end
            end
            if not hayNoFullGrown then
                print("No growable pets — buying egg: "..eggToBuy)
                pcall(function()
                    ReplicatedStorage.API:FindFirstChild("ShopAPI/BuyItem"):InvokeServer("pets", eggToBuy, {["buy_count"] = 1})
                end)
                task.wait(1)
                -- hatch it immediately if possible
                local ok2, newPets = pcall(function()
                    return ClientData.get_data()[Player.Name].inventory.pets or {}
                end)
                if ok2 then
                    for _, v in pairs(newPets) do
                        if v["id"] == eggToBuy then
                            pcall(function()
                                ReplicatedStorage.API:FindFirstChild("PetAPI/HatchEgg"):InvokeServer(v["unique"])
                            end)
                            break
                        end
                    end
                end
            end
        end)
    end

    local needToChange = false
    local petToChange  = nil
    if not Pet or not PetID then
        needToChange = true
        petToChange  = getPetToFarm()
    end
    if Pet and PetID then
        local ok2, Pets2 = pcall(function()
            return ClientData.get_data()[Player.Name].inventory.pets or {}
        end)
        if ok2 and Pets2[tostring(PetID)] and Pets2[tostring(PetID)]["properties"]["age"] == 6 then
            needToChange = true
            petToChange  = getPetToFarm()
        end
    end
    if petToChange and (not PetID or PetID ~= petToChange["unique"]) then
        changePetTo(petToChange)
    end
    if not Pet or not PetID or (needToChange and not petToChange) then
        local ok3, Pets3 = pcall(function()
            return ClientData.get_data()[Player.Name].inventory.pets or {}
        end)
        if ok3 then
            for _, v in pairs(Pets3) do
                if v["id"] ~= "practice_dog" then
                    changePetTo(v)
                    break
                end
            end
        end
    end
    print("Current pet:", Pet, PetID)
end

function cuantasPets(pets)
    local n = 0
    for _, v in pairs(pets) do
        if v["id"] ~= "practice_dog" then n += 1 end
