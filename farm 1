-- Update Pet ID
function updatePetID()
    for k,v in pairs(workspace.Pets:GetChildren()) do
        local pet = require(game:GetService("ReplicatedStorage").ClientModules.Game.PetEntities.PetEntityManager).get_pet_entity(v)
        if type(pet) == "table" and pet.session_memory and pet.session_memory.meta and pet.session_memory.meta.owned_by_local_player then
            local petData = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets
            for uniqueId, petInfo in pairs(petData) do
                if petInfo.id == pet.session_memory.pet_id then
                    PetID = uniqueId
                    return
                end
            end
        end
    end
end

-- Get baby ailments (tasks not belonging to current pet)
function getBabyAilments()
    local babyTasks = {}
    
    local success, data = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
    end)
    
    if success and data and data.ailments_manager and data.ailments_manager.ailments then
        local allAilments = data.ailments_manager.ailments
        
        for entityId, ailments in pairs(allAilments) do
            if entityId ~= tostring(PetID) then
                for taskName, taskData in pairs(ailments) do
                    babyTasks[taskName] = taskData
                    print("Baby task found:", taskName)
                end
            end
        end
    end
    
    return babyTasks
end

-- Find baby furniture
function getBabyFurniture()
    GoToHome()
    task.wait(2)
    
    babyCrib = nil
    babyShower = nil
    babyHighChair = nil
    babyPlayMat = nil
    
    if not workspace.HouseInteriors or not workspace.HouseInteriors.furniture then
        return
    end
    
    for i, v in pairs(workspace.HouseInteriors.furniture:GetChildren()) do
        if v:FindFirstChildWhichIsA("Model") then
            local Furniture = v:FindFirstChildWhichIsA("Model")
            local furnitureName = Furniture.Name:lower()
            
            if furnitureName:find("crib") or (furnitureName:find("bed") and furnitureName:find("baby")) then
                babyCrib = v.Name
                print("Found crib:", v.Name)
            elseif furnitureName:find("shower") or furnitureName:find("bath") or furnitureName:find("tub") then
                babyShower = v.Name
                print("Found shower:", v.Name)
            elseif furnitureName:find("highchair") or (furnitureName:find("chair") and furnitureName:find("baby")) then
                babyHighChair = v.Name
                print("Found highchair:", v.Name)
            elseif furnitureName:find("play") and (furnitureName:find("mat") or furnitureName:find("gym")) then
                babyPlayMat = v.Name
                print("Found play mat:", v.Name)
            end
        end
    end
end

-- Handle baby tasks
function handleBabyTask(taskName, uiElements)
    if uiElements and uiElements.taskLabel then
        uiElements.taskLabel.Text = "Current Task: " .. taskName
    end
    
    -- SLEEPY TASK
    if taskName == "sleepy" and babyCrib then
        print("Putting baby to sleep...")
        GoToHome()
        task.wait(1)
        
        pcall(function()
            local args = {
                [1] = Player,
                [2] = babyCrib:sub(#Player.Name + 13),
                [3] = "UseBlock",
                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                [5] = Player.Character
            }
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        
        task.wait(20) -- Wait for sleep to complete
        
    -- DIRTY TASK
    elseif taskName == "dirty" and babyShower then
