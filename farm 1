local Location = nil
for _, v in pairs(getgc()) do
    if type(v) == "function" then
        -- getfenv crashes on C closures — catch it
        local ok1, env = pcall(getfenv, v)
        if ok1 and type(env) == "table" and env.script then
            local ok2, isMatch = pcall(function()
                return env.script == ReplicatedStorage.ClientModules.Core.InteriorsM.InteriorsM
            end)
            if ok2 and isMatch then
                local ok3, consts = pcall(getconstants, v)
                if ok3 and consts and table.find(consts, "LocationAPI/SetLocation") then
                    Location = v
                    break
                end
            end
        end
    end
end

local function SetLocation(a, b, c)
    local k = get_thread_identity()
    set_thread_identity(2)
    wait()
    Location(a, b, c)
    set_thread_identity(k)
    wait()
end

