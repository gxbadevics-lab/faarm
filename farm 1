-- Update Pet ID
function updatePetID()
    for k,v in pairs(workspace.Pets:GetChildren()) do
        local pet = require(ReplicatedStorage.ClientModules.Game.PetEntities.PetEntityManager).get_pet_entity(v)
        if type(pet) == "table" and pet.session_memory and pet.session_memory.meta and pet.session_memory.meta.owned_by_local_player then
            local petData = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets
            for uniqueId, petInfo in pairs(petData) do
                if petInfo.id == pet.session_memory.pet_id then
                    PetID = uniqueId
                    return
                end
            end
        end
    end
end

-- Get baby ailments (tasks not belonging to current pet)
function getBabyAilments()
    local babyTasks = {}
    
    local success, data = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
    end)
    
    if success and data and data.ailments_manager and data.ailments_manager.ailments then
        local allAilments = data.ailments_manager.ailments
        
        for entityId, ailments in pairs(allAilments) do
            if entityId ~= tostring(PetID) then
                for taskName, taskData in pairs(ailments) do
                    babyTasks[taskName] = taskData
                    print("Baby task detected:", taskName)
                end
            end
        end
    end
    
    return babyTasks
end

-- Find baby furniture
function getBabyFurniture()
    GoToHome()
    task.wait(2)
    
    babyCrib = nil
    babyShower = nil
    babyHighChair = nil
    babyPlayMat = nil
    
    if not workspace.HouseInteriors or not workspace.HouseInteriors.furniture then
        return
    end
    
    for i, v in pairs(workspace.HouseInteriors.furniture:GetChildren()) do
        if v:FindFirstChildWhichIsA("Model") then
            local Furniture = v:FindFirstChildWhichIsA("Model")
            local furnitureName = Furniture.Name:lower()
            
            if furnitureName:find("crib") or (furnitureName:find("bed") and furnitureName:find("baby")) then
                babyCrib = v.Name
                print("Found crib")
            elseif furnitureName:find("shower") or furnitureName:find("bath") or furnitureName:find("tub") then
                babyShower = v.Name
                print("Found shower")
            elseif furnitureName:find("highchair") or (furnitureName:find("chair") and furnitureName:find("baby")) then
                babyHighChair = v.Name
                print("Found highchair")
            elseif furnitureName:find("play") and (furnitureName:find("mat") or furnitureName:find("gym")) then
                babyPlayMat = v.Name
                print("Found play mat")
            end
        end
    end
end

-- Handle ALL baby tasks (adapted from pet farm)
function handleBabyTask(taskName, uiElements)
    print("Starting baby task:", taskName)
    
    if uiElements and uiElements.taskLabel then
        uiElements.taskLabel.Text = "Current Task: " .. taskName
    end
    
    -- SLEEPY - Use crib
    if taskName == "sleepy" then
        if not babyCrib then
            print("No crib found for sleepy task")
            return
        end
        
        SueloTemporal()
        GoToHome()
        
        local furnitureId = babyCrib:sub(#Player.Name + 13)
        
        pcall(function()
            local args = {
                [1] = Player,
                [2] = furnitureId,
                [3] = "UseBlock",
                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                [5] = Player.Character
            }
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        
        task.wait(15)
    
    -- DIRTY - Use shower
    elseif taskName == "dirty" then
        if not babyShower then
            print("No shower found for dirty task")
            return
        end
        
        SueloTemporal()
        GoToHome()
        
        local furnitureId = babyShower:sub(#Player.Name + 13)
        
        pcall(function()
            local args = {
                [1] = Player,
                [2] = furnitureId,
                [3] = "UseBlock",
                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                [5] = Player.Character
            }
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        
        task.wait(15)
    
    -- HUNGRY - Feed with bottle
    elseif taskName == "hungry" then
        -- Get or buy baby bottle
        local Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
        local babyBottle = nil
        
        for i, v in pairs(Foods) do
            if v.id == "baby_bottle" then
                babyBottle = v.unique
                break
            end
        end
        
        if not babyBottle then
            ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_bottle", {["buy_count"] = 1})
            task.wait(1)
        end
        
        if babyBottle then
            -- Use bottle
            pcall(function()
                ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(babyBottle, {
                    use_sound_delay = true,
                    equip_as_last = false
                })
            end)
            
            task.wait(1)
            
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(babyBottle, "START")
            end)
            
            task.wait(4)
            
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(babyBottle, "END")
                ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(babyBottle)
            end)
        end
        
        task.wait(1)
    
    -- THIRSTY - Give drink
    elseif taskName == "thirsty" then
        local Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
        local drink = nil
        
