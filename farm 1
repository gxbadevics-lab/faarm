-- Count pets of a specific display name and type
function CountPetsByName(displayName, petType)
    local c = 0
    local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
    if not ok then return 0 end
    for _, v in pairs(pets) do
        local nameMatch = findPetDisplayName(v.id) == displayName
        local typeMatch = false
        if petType == "normal" then
            typeMatch = not v.properties.neon and not v.properties.mega_neon
        elseif petType == "neon" then
            typeMatch = v.properties.neon and not v.properties.mega_neon
        elseif petType == "mega" then
            typeMatch = v.properties.mega_neon == true
        end
        if nameMatch and typeMatch then c += 1 end
        task.wait()
    end
    return c
end

if autoGrow then
    spawn(function()
        while autoGrow do
            pcall(function()
                -- first do a fusion pass on whatever is already full grown
                MakeMega(false)
                MakeMega(true)

                for _, cfg in pairs(petsToGrow) do
                    local petName      = cfg.name
                    local megaGoal     = cfg.megaGoal   or 0
                    local neonGoal     = cfg.neonGoal   or 0
                    local normalGoal   = cfg.normalGoal or 0
                    local fusionOn     = cfg.fusionEnabled ~= false -- default true
                    print("--- Processing:", petName, "| Mega:", megaGoal, "Neon:", neonGoal, "Normal:", normalGoal)

                    -- MEGA GOAL
                    if megaGoal > 0 then
                        local attempts = 0
                        while attempts < 15 do
                            attempts += 1
