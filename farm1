-- Handle baby tasks
function handleBabyTask(taskName)
    print("Starting baby task:", taskName)
    
    if infoBabyStatus then
        infoBabyStatus.Text = "Baby Task: " .. taskName
    end
    
    -- SLEEPY - Use crib
    if taskName == "sleepy" and babyCrib then
        SueloTemporal()
        GoToHome()
        task.wait(1)
        
        local furnitureId = babyCrib:sub(#Player.Name + 13)
        local args = {
            [1] = Player,
            [2] = furnitureId,
            [3] = "UseBlock",
            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
            [5] = Player.Character
        }
        pcall(function()
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        task.wait(15)
    
    -- DIRTY - Use shower
    elseif taskName == "dirty" and babyShower then
        SueloTemporal()
        GoToHome()
        task.wait(1)
        
        local furnitureId = babyShower:sub(#Player.Name + 13)
        local args = {
            [1] = Player,
            [2] = furnitureId,
            [3] = "UseBlock",
            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
            [5] = Player.Character
        }
        pcall(function()
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        task.wait(15)
    
    -- BORED - Use play mat
    elseif taskName == "bored" and babyPlayMat then
        SueloTemporal()
        GoToHome()
        task.wait(1)
        
        local furnitureId = babyPlayMat:sub(#Player.Name + 13)
        local args = {
            [1] = Player,
            [2] = furnitureId,
            [3] = "UseBlock",
            [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
            [5] = Player.Character
        }
        pcall(function()
            ReplicatedStorage.API.HousingAPI.ActivateFurniture:InvokeServer(unpack(args))
        end)
        task.wait(15)
    
    -- HUNGRY/THIRSTY - Use bottle
    elseif taskName == "hungry" or taskName == "thirsty" then
        local Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
        local bottle = nil
        
        for i, v in pairs(Foods) do
            if v.id == "baby_bottle" then
                bottle = v.unique
                break
            end
        end
        
        if not bottle then
            pcall(function()
                ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_bottle", {["buy_count"] = 1})
            end)
            task.wait(1)
        end
        
        if bottle then
            local args = {
                [1] = bottle,
                [2] = "START"
            }
            pcall(function()
                ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(bottle, {use_sound_delay = true, equip_as_last = false})
            end)
            task.wait(1)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(unpack(args))
            end)
            task.wait(4)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(bottle)
            end)
        end
        task.wait(1)
    
    -- SICK - Use medicine
    elseif taskName == "sick" then
        local Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
        local medicine = nil
        
        for i, v in pairs(Foods) do
            if v.id == "baby_medicine" then
                medicine = v.unique
                break
            end
        end
        
        if not medicine then
            pcall(function()
                ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_medicine", {["buy_count"] = 1})
            end)
            task.wait(1)
        end
        
        if medicine then
            local args = {
                [1] = medicine,
                [2] = "START"
            }
            pcall(function()
                ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(medicine, {use_sound_delay = true, equip_as_last = false})
            end)
            task.wait(1)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(unpack(args))
            end)
            task.wait(3)
            pcall(function()
                ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(medicine)
            end)
        end
        task.wait(1)
    
    -- PLAY - Use toy
    elseif taskName == "play" then
        local Toys = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.toys or {}
        for _, v in pairs(Toys) do
            local args = {
                [1] = v.unique,
