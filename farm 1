-- eggs prioritised when autoEggFarm is on
function getPetToFarm()
    local ok, Pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets or {} end)
    if not ok then return nil end
    if autoEggFarm then
        for _, v in pairs(Pets) do if isEgg(v["id"]) then return v end end
    end
    local maxAge, best = 0, nil
    for _, v in pairs(Pets) do
        if v["id"] ~= "practice_dog" and not isEgg(v["id"])
            and v["properties"]["age"] > maxAge and v["properties"]["age"] < 6
            and v["properties"]["neon"] then
            maxAge = v["properties"]["age"] best = v
        end
    end
    if best then return best end
    maxAge = 0
    for _, v in pairs(Pets) do
        if v["id"] ~= "practice_dog" and not isEgg(v["id"])
            and v["properties"]["age"] > maxAge and v["properties"]["age"] < 6 then
            maxAge = v["properties"]["age"] best = v
        end
    end
    return best
end

function changePetTo(pet)
    if not (pet and pet["unique"]) then return end
    PetID = pet["unique"]
    pcall(function() ReplicatedStorage.API["ToolAPI/Unequip"]:InvokeServer(PetID) end)
    pcall(function() ReplicatedStorage.API["ToolAPI/Equip"]:InvokeServer(PetID) end)
    Pet = nil
    local t = 0
    while not Pet and t < 3 do Pet = getPet() task.wait(0.1) t += 0.1 end
    if isEgg(pet["id"]) then
        print("[Farm] Egg equipped (Pet=nil is normal):", pet["id"], "| PetID:", PetID)
    else
        print("[Farm] Pet equipped:", pet["id"], "| PetID:", PetID, "| Pet:", tostring(Pet))
    end
end

function checkIfINeedToChange()
    local ok, Pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets or {} end)
    if not ok then return end

    if autoEggFarm then
        local hasFarmable = false
        for _, v in pairs(Pets) do
            if v["id"] ~= "practice_dog" then
                if isEgg(v["id"]) or v["properties"]["age"] < 6 then hasFarmable = true break end
            end
        end
        if not hasFarmable then
            print("[Farm] Nothing to farm — buying egg:", eggToBuy)
            pcall(function()
                ReplicatedStorage.API:FindFirstChild("ShopAPI/BuyItem"):InvokeServer("pets", eggToBuy, {["buy_count"]=1})
            end)
            task.wait(1.5)
            ok, Pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets or {} end)
            if not ok then Pets = {} end
            Pet = nil PetID = nil
        end
    end

    local needToChange = not PetID
    if PetID then
        local ok2, curPet = pcall(function()
            return ClientData.get_data()[Player.Name].inventory.pets[tostring(PetID)]
        end)
        if ok2 and curPet then
            if not isEgg(curPet["id"]) and curPet["properties"]["age"] == 6 then needToChange = true end
        else
            needToChange = true
        end
    end

    if needToChange then
        local best = getPetToFarm()
        if best then
            changePetTo(best)
        else
            for _, v in pairs(Pets) do
                if v["id"] ~= "practice_dog" then changePetTo(v) break end
            end
        end
    end
end

