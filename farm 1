local function FGPet_AG(petUID)
    if CheckFG_AG(petUID) then return end
    pcall(function()
        game.ReplicatedStorage:WaitForChild("API"):WaitForChild("ToolAPI/Equip"):InvokeServer(petUID)
        repeat task.wait() until ClientDataAG.get_data()[Player.Name].pet_char_wrappers[1]
        while task.wait() do
