    -- Baby needs display
    local needsLabel = createLabel(frame, 0.52, "Baby Needs: Checking...")
    
    -- Time elapsed
    local startTime = os.time()
    local timeLabel = createLabel(frame, 0.58, "Time: 0h 0min")
    
    screenGui.Parent = Player:WaitForChild("PlayerGui")
    
    -- Update UI loop
    spawn(function()
        while _G.autofarm do
            local babyAilments = getBabyAilments()
            if babyAilments and next(babyAilments) then
                local needs = ""
                for need, value in pairs(babyAilments) do
                    needs = needs .. need .. " "
                end
                needsLabel.Text = "Baby Needs: " .. needs
            else
                needsLabel.Text = "Baby Needs: None or Unknown"
            end
            
            local elapsedTime = os.difftime(os.time(), startTime)
            local elapsedMinutes = math.floor(elapsedTime / 60)
            local elapsedHours = math.floor(elapsedMinutes / 60)
            timeLabel.Text = "Time: " .. elapsedHours .. "h " .. elapsedMinutes % 60 .. "min"
            
            task.wait(2)
        end
    end)
    
    -- Start baby farm
    task.wait(2)
    startBabyFarm()
end

