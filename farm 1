local Location
for i, v in pairs(getgc()) do
    if type(v) == "function" then
        if pcall(function() return getfenv(v).script == ReplicatedStorage.ClientModules.Core.InteriorsM.InteriorsM end) then
            if table.find(getconstants(v), "LocationAPI/SetLocation") then
