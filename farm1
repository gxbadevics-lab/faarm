spawn(function()
    while _G.autofarm and babyFarm do
        pcall(function()
            if not isPlayerBaby() then
                statusText.Text = "Becoming baby..."
                becomeBaby()
                task.wait(3)
            else
                statusText.Text = "Baby mode active"
                
                -- Get baby furniture if needed
                if not babyCrib or not babyShower then
                    getBabyFurniture()
                end
                
                -- Get baby tasks
                local babyTasks = getBabyTasks()
                
                -- Do tasks
                if next(babyTasks) and not isBabyDoingTask then
                    for taskName, _ in pairs(babyTasks) do
                        isBabyDoingTask = true
