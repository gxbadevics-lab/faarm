-- Utility functions
function table_contains(tbl, x)
    for _, v in pairs(tbl) do
        if v == x then return true end
    end
    return false
end

function findPetDisplayName(petID)
    if not InventoryDB then return petID end
    for _, entry in pairs(InventoryDB.pets) do
        if type(entry) == "table" and tostring(entry.id) == tostring(petID) then
            return entry.name
        end
    end
    return petID
end

-- MODIFIED: isEgg now just identifies eggs but doesn't treat them differently for tasks
function isEgg(petID)
    if not InventoryDB then
        return string.find(string.lower(tostring(petID)), "egg") ~= nil
    end
    for _, entry in pairs(InventoryDB.pets) do
        if type(entry) == "table" and tostring(entry.id) == tostring(petID) then
            return entry.is_egg == true
        end
    end
    return false
end

