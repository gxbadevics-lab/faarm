local isDoingTask  = false
local isInWaitLoop = false

function startPetFarm()
    spawn(function()
        while true do
            if _G.autofarm then
                -- ensure furniture is set up
                while not AilmentFurnitues["generic_crib"]
                    or not AilmentFurnitues["generic_shower"]
                    or not AilmentFurnitues["generic_toilet"] do
                    AilmentFurnitues["generic_crib"]    = Type("generic_crib")
                    AilmentFurnitues["generic_shower"]  = Type("generic_shower")
                    AilmentFurnitues["generic_toilet"]  = TypeSeat("generic_toilet")
                    if not AilmentFurnitues["generic_crib"] then
                        pcall(function()
                            ReplicatedStorage.API:FindFirstChild("HousingAPI/BuyFurnitures"):InvokeServer({
                                {
                                    properties = { cframe = CFrame.new(19.5, 0, -30) * CFrame.Angles(0, 1.5707963705062866, 0) },
                                    kind = "basiccrib"
                                }
                            })
                        end)
                        task.wait(0.5)
                    end
                    task.wait(0.1)
                end

                spawn(function()
                    local Tasks = {
                        "hungry","sleepy","thirsty","bored","dirty","camping","sick",
                        "school","hot_spring","salon","pizza_party","pool_party",
                        "beach_party","play","toilet","ride","walk","pet_me",
                    }
                    local Ailments = getAilments()
                    local Ailment  = nil
                    if type(Ailments) == "table" then
                        for k, _ in pairs(Ailments) do
                            if table_contains(Tasks, k) then Ailment = k break end
                        end
                    end
                    if not Ailment and not isDoingTask then
                        print("Waiting for task...")
                    end
                    if Ailment and not isDoingTask and Pet and PetID then
                        local Name = Ailment
                        print("NEW TASK:", Name, "| Pet:", PetID)
                        isDoingTask = Name

                        -- timeout watcher
                        spawn(function()
                            if isInWaitLoop then return end
                            local tiempo = 0
                            isInWaitLoop = true
                            while isDoingTask do
                                if tiempo > 120 or not _G.autofarm or not Pet then
                                    print("Task timeout — resetting pet equip")
                                    isDoingTask  = false
                                    isInWaitLoop = false
                                    pcall(function()
                                        ReplicatedStorage.API["ToolAPI/Unequip"]:InvokeServer(PetID)
                                        ReplicatedStorage.API["ToolAPI/Equip"]:InvokeServer(PetID)
                                    end)
                                    task.wait(11)
                                    break
                                end
                                local curAilments = getAilments()
                                local stillActive = false
                                if type(curAilments) == "table" then
                                    for k, _ in pairs(curAilments) do
                                        if k == Name then stillActive = true end
                                    end
                                else
                                    stillActive = true
                                end
                                if not stillActive then
                                    print("Task completed:", Name)
                                    isDoingTask  = false
                                    isInWaitLoop = false
                                    break
                                end
                                tiempo += 1
                                task.wait(1)
                            end
                            isInWaitLoop = false
                        end)

                        -- task handler
                        spawn(function()
                            if Name == "sleepy" then
                                SueloTemporal()
                                pcall(function() ReplicatedStorage.API:FindFirstChild("AdoptAPI/HoldBaby"):FireServer(Pet) end)
                                GoToHome()
                                while isDoingTask == "sleepy" do
                                    local fname = AilmentFurnitues["generic_crib"]:sub(#Player.Name + 13)
                                    while not Player.Character:FindFirstChild("HumanoidRootPart") do task.wait(1) end
                                    pcall(function()
                                        ReplicatedStorage.API["HousingAPI/ActivateFurniture"]:InvokeServer(
                                            Player, fname, "UseBlock",
                                            {cframe = Player.Character.HumanoidRootPart.CFrame}, Pet)
                                    end)
                                    task.wait(10)
                                end

                            elseif Name == "dirty" then
                                SueloTemporal()
                                pcall(function() ReplicatedStorage.API:FindFirstChild("AdoptAPI/HoldBaby"):FireServer(Pet) end)
                                GoToHome()
                                while isDoingTask == "dirty" do
                                    local fname = AilmentFurnitues["generic_shower"]:sub(#Player.Name + 13)
                                    while not Player.Character:FindFirstChild("HumanoidRootPart") do task.wait(1) end
                                    pcall(function()
                                        ReplicatedStorage.API["HousingAPI/ActivateFurniture"]:InvokeServer(
                                            Player, fname, "UseBlock",
                                            {cframe = Player.Character.HumanoidRootPart.CFrame}, Pet)
                                    end)
