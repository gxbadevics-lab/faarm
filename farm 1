-- PET FARM: get the oldest pet by age (any age including 6, never skip full grown)
function getPetToFarm()
    local Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}
    local maxAge = -1
    local best = nil
    for k, v in pairs(Pets) do
        if v['id'] ~= "practice_dog" then
            if v['properties']['age'] > maxAge then
                maxAge = v['properties']['age']
                best = v
            end
        end
    end
    return best
end

-- EGG FARM: find first pet matching eggFarmList priority order
-- returns the pet data table, or nil if nothing found
function getEggFarmPet()
    local Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}
    -- try each entry in priority order
    for _, wantedID in ipairs(eggFarmList) do
        for k, v in pairs(Pets) do
            if v['id'] == wantedID and v['id'] ~= "practice_dog" then
                return v
            end
        end
    end
    -- fallback: return any pet if none from list found
    for k, v in pairs(Pets) do
        if v['id'] ~= "practice_dog" then
            return v
        end
    end
    return nil
end

function changePetTo(pet)
    if pet and pet['unique'] then
        PetID = pet['unique']
        ReplicatedStorage.API["ToolAPI/Unequip"]:InvokeServer(PetID)
        algo = ReplicatedStorage.API["ToolAPI/Equip"]:InvokeServer(PetID)
        Pet = nil
        local timeTrying = 0
        while not Pet do
            Pet = getPet()
            task.wait(0.1)
            timeTrying += 0.1
            if timeTrying >= 5 then break end
        end
    end
end

function checkIfINeedToChange()
    local Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}

    if autoEggFarm then
        -- EGG FARM MODE
        -- check if a higher-priority pet from the list appeared that we should switch to
        local wantedPet = nil
        for _, wantedID in ipairs(eggFarmList) do
            for k, v in pairs(Pets) do
                if v['id'] == wantedID and v['id'] ~= "practice_dog" then
                    wantedPet = v
                    break
                end
            end
            if wantedPet then break end
        end

        if wantedPet then
            -- switch to highest priority listed pet if not already on it
            if not PetID or PetID ~= wantedPet['unique'] then
                print("EggFarm: switching to priority pet:", wantedPet['id'])
                changePetTo(wantedPet)
            end
        else
            -- none from list exists, use fallback or buy
            local anyPet = nil
            for k, v in pairs(Pets) do
                if v['id'] ~= "practice_dog" then anyPet = v break end
            end
            if anyPet then
                if not PetID then
                    print("EggFarm: no listed pets, farming fallback:", anyPet['id'])
                    changePetTo(anyPet)
                end
            else
                -- completely out of pets
                if autoBuyEgg and #eggFarmList > 0 then
                    print("EggFarm: out of pets, buying:", eggFarmList[1])
                    local buyArgs = {
                        [1] = "pets",
                        [2] = eggFarmList[1],
                        [3] = {["buy_count"] = 1}
                    }
                    game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("ShopAPI/BuyItem"):InvokeServer(unpack(buyArgs))
                    task.wait(1)
                end
            end
        end
    else
        -- PET FARM MODE: equip oldest pet on startup, then NEVER switch
        -- only equip if we have no pet at all right now
        if not Pet or not PetID then
            local oldest = getPetToFarm()
            if oldest then
                print("PetFarm: equipping oldest pet (age "..oldest['properties']['age'].."):", oldest['id'])
                changePetTo(oldest)
            end
        end
        -- if pet got unparented (kicked from world etc), re-equip same one
        if Pet and not Pet.Parent then
            Pet = nil
            -- try to re-equip the same PetID first
            if PetID then
                local ok, curPet = pcall(function()
                    return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets[tostring(PetID)]
                end)
                if ok and curPet then
                    changePetTo(curPet)
                else
                    -- pet no longer exists, get oldest
                    local oldest = getPetToFarm()
                    if oldest then changePetTo(oldest) end
                end
            end
        end
    end
    print(Pet, PetID)
end

