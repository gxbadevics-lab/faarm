function table_contains(tbl, x)
    for _, v in pairs(tbl) do
        if v == x then return true end
    end
    return false
end

function findPetDisplayName(petID)
    if not InventoryDB then return petID end
    for _, entry in pairs(InventoryDB.pets) do
        if type(entry) == "table" and string.lower(tostring(entry.id)) == string.lower(tostring(petID)) then
            return entry.name
        end
    end
    return petID
end

function CheckInvisiblePet(petID)
    if not InventoryDB then return false end
    for _, entry in pairs(InventoryDB.pets) do
        if type(entry) == "table" and string.lower(tostring(entry.id)) == string.lower(tostring(petID)) then
            return entry.temporary == true
        end
    end
    return false
end

function CheckFG(pet_unique)
    local ok, pets = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets
    end)
    if not ok then return false end
    for i, v in pairs(pets) do
        if i == pet_unique then
