local current_potion_type = potionType

function FGPet(petID)
    if CheckFG(petID) then return end
    pcall(function()
        ReplicatedStorage:WaitForChild("API"):WaitForChild("ToolAPI/Equip"):InvokeServer(petID)
        repeat task.wait() until ClientData.get_data()[Player.Name].pet_char_wrappers[1]

        while task.wait() do
            local wrapper = ClientData.get_data()[Player.Name].pet_char_wrappers[1]
            if not wrapper or wrapper.pet_progression["age"] >= 6 then break end

            local potionId, potionTable = nil, {}
            local potionCount = GetMultiPotCount(petID, current_potion_type)

            for l, o in pairs(ClientData.get_data()[Player.Name].inventory.food) do
                if o.id == current_potion_type then
                    if not potionId then potionId = l
                    elseif #potionTable + 1 < potionCount then table.insert(potionTable, l) end
                end
            end

            if not potionId then
                if current_potion_type == "pet_age_potion" then
                    current_potion_type = "tiny_pet_age_potion"
                    return FGPet(petID)
                else
                    current_potion_type = "pet_age_potion"
                    print("Out of potions!")
                    break
                end
            end

            if CheckPetEquipID(petID) then
                task.wait(1)
                local ok, _ = pcall(function()
                    RouterClient.get("PetObjectAPI/CreatePetObject"):InvokeServer(
                        "__Enum_PetObjectCreatorType_2",
                        {pet_unique=petID, unique_id=potionId, additional_consume_uniques=potionTable})
                end)
                if ok then
                    repeat task.wait()
                        pcall(function()
                            RouterClient.get("PetAPI/ConsumeFoodObject"):FireServer(
                                workspace.PetObjects:FindFirstChildWhichIsA("Model"), petID)
                        end)
                    until not (workspace.PetObjects:FindFirstChild("AgePotion") or workspace.PetObjects:FindFirstChild("TinyAgePotion"))
                end
            else break end
        end
        print("FG done:", petID)
    end)
end

local function getFullgrownPets(forMega)
    local result = {}
    local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
    if not ok then return result end
    for _, v in pairs(pets) do
        local match = false
        if forMega then match = v.properties.age==6 and v.properties.neon and not v.properties.mega_neon
        else match = v.properties.age==6 and not v.properties.neon and not v.properties.mega_neon end
        if match then
            if not result[v.id] then result[v.id] = {count=0, unique={}} end
            result[v.id].count += 1
            table.insert(result[v.id].unique, v.unique)
            if result[v.id].count >= 4 then break end
        end
    end
    return result
end

function MakeMega(forMega)
    repeat
        local fusionReady = {}
        local groups = getFullgrownPets(forMega)
        for _, g in pairs(groups) do
            if g.count >= 4 then
                fusionReady = {g.unique[1], g.unique[2], g.unique[3], g.unique[4]}
                break
            end
        end
        if #fusionReady >= 4 then
            pcall(function()
                ReplicatedStorage.API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer({unpack(fusionReady)})
            end)
            task.wait(0.5)
        end
    until #fusionReady < 4
end

function CountPetsByName(displayName, petType)
    local c = 0
    local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
    if not ok then return 0 end
    for _, v in pairs(pets) do
        local nameMatch = findPetDisplayName(v.id) == displayName
        local typeMatch = false
        if petType == "normal" then typeMatch = not v.properties.neon and not v.properties.mega_neon
        elseif petType == "neon" then typeMatch = v.properties.neon and not v.properties.mega_neon
        elseif petType == "mega" then typeMatch = v.properties.mega_neon == true end
        if nameMatch and typeMatch then c += 1 end
        task.wait()
    end
    return c
end

spawn(function()
    while autoGrow do
        pcall(function()
            MakeMega(false) MakeMega(true)
            for _, cfg in pairs(petsToGrow) do
                local petName    = cfg.name
                local megaGoal   = cfg.megaGoal   or 0
                local neonGoal   = cfg.neonGoal   or 0
                local normalGoal = cfg.normalGoal or 0
                local fusionOn   = cfg.fusionEnabled ~= false
                print("--- Processing:", petName)

                if megaGoal > 0 then
                    for _ = 1, 15 do
                        local curMega = CountPetsByName(petName, "mega")
                        if curMega >= megaGoal then break end
                        local curNeon   = CountPetsByName(petName, "neon")
                        local curNormal = CountPetsByName(petName, "normal")
                        local total   = (curNeon*4) + curNormal
                        local needed  = (megaGoal-curMega)*16
                        local counter = math.min(needed, total-(total%16))
                        if counter <= 0 then break end
                        local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id)==petName and v.properties.neon and not v.properties.mega_neon then
                                    if GetPotions(current_potion_type) > 0 then FGPet(uid) counter -= 4 else break end
                                end task.wait()
                            end
                        end
                        ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id)==petName and not v.properties.neon and not v.properties.mega_neon then
                                    if GetPotions(current_potion_type) > 0 then FGPet(uid) counter -= 1 else break end
                                end task.wait()
                            end
                        end
                        if fusionOn then MakeMega(false) MakeMega(true) end
                        if GetPotions(current_potion_type) == 0 then break end
                        task.wait(2)
                    end
                end

                if neonGoal > 0 then
                    for _ = 1, 15 do
                        local curNeon = CountPetsByName(petName, "neon")
                        if curNeon >= neonGoal then break end
                        local curNormal = CountPetsByName(petName, "normal")
                        local counter   = math.min((neonGoal-curNeon)*4, curNormal-(curNormal%4))
                        if counter <= 0 then break end
                        local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id)==petName and not v.properties.neon and not v.properties.mega_neon then
                                    if GetPotions(current_potion_type) > 0 then FGPet(uid) counter -= 1 else break end
                                end task.wait()
                            end
                        end
                        if fusionOn then MakeMega(false) end
                        if GetPotions(current_potion_type) == 0 then break end
                        task.wait(2)
                    end
                end

                if normalGoal > 0 then
                    for _ = 1, 15 do
                        local fullNormal = 0
                        local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
                        if ok then
                            for _, v in pairs(pets) do
                                if findPetDisplayName(v.id)==petName and not v.properties.neon
                                    and not v.properties.mega_neon and v.properties.age==6 then
                                    fullNormal += 1
                                end
                            end
                        end
                        if fullNormal >= normalGoal then break end
                        local counter = normalGoal - fullNormal
                        if ok then
                            for uid, v in pairs(pets) do
                                if counter <= 0 then break end
                                if findPetDisplayName(v.id)==petName and not v.properties.neon
                                    and not v.properties.mega_neon and v.properties.age < 6 then
                                    if GetPotions(current_potion_type) > 0 then FGPet(uid) counter -= 1 else break end
                                end task.wait()
                            end
                        end
                        if GetPotions(current_potion_type) == 0 then break end
                        task.wait(2)
                    end
                end

                print("Done with:", petName)
                task.wait(3)
            end
        end)
        task.wait(120)
    end
end)

