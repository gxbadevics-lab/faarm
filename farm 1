-- Find Location function safely
local Location = nil
pcall(function()
    for i, v in pairs(getgc()) do
        if type(v) == "function" then
            local env = getfenv(v)
            if env and env.script == ReplicatedStorage.ClientModules.Core.InteriorsM.InteriorsM then
                local constants = getconstants(v)
                if constants and table.find(constants, "LocationAPI/SetLocation") then
                    Location = v
                    break
                end
            end
        end
    end
end)

local function SetLocation(a, b, c)
    if not Location then return false end
    local k = get_thread_identity and get_thread_identity() or 2
    pcall(set_thread_identity, 2)
    wait()
    pcall(Location, a, b, c)
    pcall(set_thread_identity, k)
    wait()
    return true
end

-- Location functions
function Home()
    if workspace.HouseInteriors.blueprint:FindFirstChildWhichIsA("Model") then
        return workspace.HouseInteriors.blueprint:FindFirstChildWhichIsA("Model").Name
    else
        return false
    end
end

function Store()
    if workspace.Interiors:FindFirstChildWhichIsA("Model") then
        if (workspace.Interiors:FindFirstChildWhichIsA("Model").Name ~= "MainMap") and (workspace.Interiors:FindFirstChildWhichIsA("Model").Name ~= "Neighborhood") then
            return workspace.Interiors:FindFirstChildWhichIsA("Model").Name
        else
            return false
        end
    else
        return false
    end
end

function MainMap()
    if workspace.Interiors:FindFirstChildWhichIsA("Model") then
        if string.find(workspace.Interiors:FindFirstChildWhichIsA("Model").Name, "MainMap") then
            return workspace.Interiors:FindFirstChildWhichIsA("Model").Name
        else
            return false
        end
    else
        return false
    end
end

function Neighborhood()
    if workspace.Interiors:FindFirstChildWhichIsA("Model") then
        if workspace.Interiors:FindFirstChildWhichIsA("Model").Name == "Neighborhood" then
            return workspace.Interiors:FindFirstChildWhichIsA("Model").Name
        else
            return false
        end
    else
        return false
    end
end

function GoToStore(Name)
    if Store() == Name then
        return true
    end
    SetLocation(Name, "MainDoor", {})
    while Store() ~= Name do
        task.wait()
    end
    return true
end

function GoToHome()
    if Home() then
        return true
    end
    SetLocation("housing", "MainDoor", {["house_owner"] = Player})
    while not Home() do
        task.wait(1)
    end
    return true
end

function GoToNeighborhood()
    SetLocation("Neighborhood", "MainDoor", {})
    while not Neighborhood() do
        task.wait()
    end
    return true
end

function GoToMainMap()
    if MainMap() then
        return true
    end
    SetLocation("MainMap", "Neighborhood/MainDoor", {})
    while not MainMap() do
        task.wait()
    end
    return true
end

