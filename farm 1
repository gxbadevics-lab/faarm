-- THE FIX: Look at ALL ailments and find tasks that don't belong to PetID
function getBabyAilments()
    local babyTasks = {}
    
    -- Get all ailments from client data
    local success, data = pcall(function()
        return require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name]
    end)
    
    if success and data and data.ailments_manager and data.ailments_manager.ailments then
        local allAilments = data.ailments_manager.ailments
        
        -- Look through every entity that has ailments
        for entityId, ailments in pairs(allAilments) do
            -- If this entity is NOT our current pet, then it must be something else (baby, another pet, etc.)
            if entityId ~= tostring(PetID) then
                print("Found ailments for entity:", entityId, "(not current pet)")
                
                -- Add all ailments from this entity to baby tasks
                for taskName, taskData in pairs(ailments) do
                    babyTasks[taskName] = taskData
                    print("  - Added baby task:", taskName)
                end
            end
        end
    end
    
    return babyTasks
end

-- Update PetID from pet farm (simplified version)
function updatePetID()
    -- Try to get current pet ID from equipped pet
    for k,v in pairs(workspace.Pets:GetChildren()) do
        local pet = require(game:GetService("ReplicatedStorage").ClientModules.Game.PetEntities.PetEntityManager).get_pet_entity(v)
        if type(pet) == "table" and pet.session_memory and pet.session_memory.meta and pet.session_memory.meta.owned_by_local_player then
            -- Found our pet, get its ID
            local petData = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets
            for uniqueId, petInfo in pairs(petData) do
                if petInfo.id == pet.session_memory.pet_id then
                    PetID = uniqueId
                    print("Current Pet ID:", PetID)
                    return
                end
            end
        end
    end
end

function getBabyFurniture(type)
    GoToHome()
    task.wait(2)
    
    if not workspace.HouseInteriors or not workspace.HouseInteriors.furniture then
        return nil
    end
    
    for i, v in pairs(workspace.HouseInteriors.furniture:GetChildren()) do
        if v:FindFirstChildWhichIsA("Model") then
            local Furniture = v:FindFirstChildWhichIsA("Model")
            local furnitureName = Furniture.Name:lower()
            
            if type == "crib" and (furnitureName:find("crib") or furnitureName:find("baby") and furnitureName:find("bed")) then
                print("Found crib: " .. v.Name)
                return v.Name
            elseif type == "shower" and (furnitureName:find("shower") or furnitureName:find("bath") or furnitureName:find("tub")) then
                print("Found shower: " .. v.Name)
                return v.Name
            elseif type == "highchair" and furnitureName:find("highchair") then
                print("Found highchair: " .. v.Name)
                return v.Name
            end
        end
    end
    return nil
end

-- Main baby farm loop
function startBabyFarm(uiElements)
    spawn(function()
        while _G.autofarm do
            pcall(function()
                if babyFarmEnabled then
                    -- Update current pet ID
                    updatePetID()
                    
                    -- Check if we're a baby
                    if not isPlayerBaby() then
                        if uiElements and uiElements.statusLabel then
                            uiElements.statusLabel.Text = "Status: Becoming Baby..."
                        end
                        becomeBaby()
                        task.wait(5)
                    else
                        if uiElements and uiElements.statusLabel then
                            uiElements.statusLabel.Text = "Status: Baby Mode Active"
                        end
                        
                        -- Get baby tasks (ailments that aren't from current pet)
                        local babyTasks = getBabyAilments()
                        
                        -- Find furniture if needed
                        if not babyCrib then
                            babyCrib = getBabyFurniture("crib")
                        end
                        if not babyShower then
                            babyShower = getBabyFurniture("shower")
                        end
                        if not babyHighChair then
                            babyHighChair = getBabyFurniture("highchair")
                        end
                        
                        -- Update furniture status
                        if uiElements and uiElements.furnitureLabel then
                            uiElements.furnitureLabel.Text = string.format(
                                "Crib: %s | Shower: %s | Chair: %s",
                                babyCrib and "✓" or "?",
                                babyShower and "✓" or "?",
                                babyHighChair and "✓" or "?"
                            )
                        end
                        
                        -- Update needs display
                        if uiElements and uiElements.needsLabel then
                            if babyTasks and next(babyTasks) then
                                local needs = ""
                                for task, _ in pairs(babyTasks) do
                                    needs = needs .. tostring(task):gsub("_", " ") .. "\n"
                                end
                                uiElements.needsLabel.Text = "Baby Needs:\n" .. needs
                            else
                                uiElements.needsLabel.Text = "Baby Needs: None"
                            end
                        end
                        
                        -- Handle baby tasks
                        if babyTasks and next(babyTasks) and not isBabyDoingTask then
                            -- Find first task
                            for taskName, taskData in pairs(babyTasks) do
                                print("Starting baby task:", taskName)
                                isBabyDoingTask = taskName
                                
                                if taskName == "sleepy" and babyCrib then
                                    if uiElements and uiElements.statusLabel then
                                        uiElements.statusLabel.Text = "Status: Putting to Sleep"
                                    end
                                    
                                    GoToHome()
                                    task.wait(1)
                                    
                                    pcall(function()
                                        local api = ReplicatedStorage.API:FindFirstChild("HousingAPI/ActivateFurniture")
                                        if api and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                                            local args = {
                                                [1] = Player,
                                                [2] = babyCrib:sub(#Player.Name + 13),
                                                [3] = "UseBlock",
                                                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                                                [5] = Player.Character
                                            }
                                            api:InvokeServer(unpack(args))
                                        end
                                    end)
                                    
                                    task.wait(15)
                                    
                                elseif taskName == "dirty" and babyShower then
                                    if uiElements and uiElements.statusLabel then
                                        uiElements.statusLabel.Text = "Status: Bathing"
                                    end
                                    
                                    GoToHome()
                                    task.wait(1)
                                    
                                    pcall(function()
                                        local api = ReplicatedStorage.API:FindFirstChild("HousingAPI/ActivateFurniture")
                                        if api and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                                            local args = {
                                                [1] = Player,
                                                [2] = babyShower:sub(#Player.Name + 13),
                                                [3] = "UseBlock",
                                                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                                                [5] = Player.Character
                                            }
                                            api:InvokeServer(unpack(args))
                                        end
                                    end)
                                    
                                    task.wait(15)
                                    
                                elseif (taskName == "hungry" or taskName == "thirsty") and babyHighChair then
                                    if uiElements and uiElements.statusLabel then
                                        uiElements.statusLabel.Text = "Status: Feeding"
                                    end
                                    
                                    GoToHome()
                                    task.wait(1)
                                    
                                    -- Put in high chair
                                    pcall(function()
                                        local api = ReplicatedStorage.API:FindFirstChild("HousingAPI/ActivateFurniture")
                                        if api and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                                            local chairArgs = {
                                                [1] = Player,
                                                [2] = babyHighChair:sub(#Player.Name + 13),
                                                [3] = "Seat1",
                                                [4] = {["cframe"] = Player.Character.HumanoidRootPart.CFrame},
                                                [5] = Player.Character
                                            }
                                            api:InvokeServer(unpack(chairArgs))
                                        end
                                    end)
                                    
                                    task.wait(2)
                                    
                                    -- Use baby bottle
                                    local Foods = {}
                                    pcall(function()
                                        Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
                                    end)
                                    
                                    local babyBottle = nil
                                    for i, v in pairs(Foods) do
                                        if v.id == "baby_bottle" then
                                            babyBottle = v.unique
                                            break
                                        end
                                    end
                                    
                                    if not babyBottle then
                                        pcall(function()
                                            ReplicatedStorage.API.ShopAPI.BuyItem:InvokeServer("food", "baby_bottle", {["buy_count"] = 1})
                                        end)
                                        task.wait(2)
                                    end
                                    
                                    if babyBottle then
                                        pcall(function()
                                            ReplicatedStorage.API.ToolAPI.Equip:InvokeServer(babyBottle, {
                                                use_sound_delay = true,
                                                equip_as_last = false
                                            })
                                        end)
                                        
                                        task.wait(1)
                                        
                                        pcall(function()
                                            ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(babyBottle, "START")
                                        end)
                                        
                                        task.wait(4)
                                        
                                        pcall(function()
                                            ReplicatedStorage.API.ToolAPI.ServerUseTool:FireServer(babyBottle, "END")
                                            ReplicatedStorage.API.ToolAPI.Unequip:InvokeServer(babyBottle)
                                        end)
                                    end
                                    
                                    task.wait(5)
                                end
                                
                                isBabyDoingTask = false
                                break -- Only do one task at a time
                            end
                        end
                    end
                else
                    -- If disabled, make sure we're parent
                    if isPlayerBaby() then
                        becomeParent()
                    end
                    task.wait(1)
                end
            end)
            task.wait(2)
        end
    end)
end

