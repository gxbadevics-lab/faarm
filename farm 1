-- ============================================================
-- PATCHED: getPetToFarm
-- Eggs get PRIORITY when autoEggFarm=true,
-- otherwise falls back to normal neon/pet picking logic.
-- ============================================================
function getPetToFarm()
    local ok, Pets = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets or {}
    end)
    if not ok then return nil end

    -- 1) Eggs first if autoEggFarm is on (equip egg, do tasks, it hatches naturally)
    if autoEggFarm then
        for _, v in pairs(Pets) do
            if isEgg(v["id"]) then
                return v
            end
        end
    end

    -- 2) Prefer neons in progress
    local maxAge, best = 0, nil
    for _, v in pairs(Pets) do
        if v["id"] ~= "practice_dog" and not isEgg(v["id"])
            and v["properties"]["age"] > maxAge and v["properties"]["age"] < 6
            and v["properties"]["neon"] then
            maxAge = v["properties"]["age"]
            best   = v
        end
    end
    if best then return best end

    -- 3) Any non-full-grown pet
    maxAge = 0
    for _, v in pairs(Pets) do
        if v["id"] ~= "practice_dog" and not isEgg(v["id"])
            and v["properties"]["age"] > maxAge and v["properties"]["age"] < 6 then
            maxAge = v["properties"]["age"]
            best   = v
        end
    end
    return best
end

