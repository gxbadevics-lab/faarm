-- IMPROVED: Hatch egg using potion method
function hatchEgg(pet_unique, petID)
    print("Hatching egg:", petID)
    
    -- Equip the egg
    pcall(function()
        RS:WaitForChild("API"):WaitForChild("ToolAPI/Equip"):InvokeServer(pet_unique)
        repeat task.wait() until ClientData.get_data()[Player.Name].pet_char_wrappers[1]
    end)
    
    -- Try to use age potion to hatch
    local potionUsed = false
    local potionTypes = {"pet_age_potion", "tiny_pet_age_potion"}
    
    for _, potType in ipairs(potionTypes) do
        if not potionUsed then
            pcall(function()
                local potionId = nil
                for l, o in pairs(ClientData.get_data()[Player.Name].inventory.food) do
                    if o.id == potType then 
                        potionId = l 
                        break
                    end
                end
                if potionId then
                    RouterClient.get("PetObjectAPI/CreatePetObject"):InvokeServer(
                        "__Enum_PetObjectCreatorType_2",
                        {pet_unique = pet_unique, unique_id = potionId, additional_consume_uniques = {}}
                    )
                    task.wait(0.5)
                    if workspace.PetObjects:FindFirstChild("AgePotion") or workspace.PetObjects:FindFirstChild("TinyAgePotion") then
                        RouterClient.get("PetAPI/ConsumeFoodObject"):FireServer(
                            workspace.PetObjects:FindFirstChildWhichIsA("Model"), pet_unique)
                        potionUsed = true
                        print("Used", potType, "to hatch egg")
                    end
                end
            end)
        end
        task.wait(1)
    end
    
    if not potionUsed then
        print("No potions to hatch egg - will try to buy potion or wait")
    end
    
    task.wait(2)
end

-- IMPROVED: Check if we need to change pet and handle egg farming
function checkIfINeedToChange()
    local ok, Pets = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets or {}
    end)
    if not ok then return end

    -- Check if current pet is equipped and valid
    local needSwitch = false
    local currentPetData = nil
    
    if Pet and PetID then
        local ok2, curPet = pcall(function()
            return ClientData.get_data()[Player.Name].inventory.pets[tostring(PetID)]
        end)
        if ok2 and curPet then
            currentPetData = curPet
            -- Check if current pet is valid to keep farming
            if curPet["id"] == "practice_dog" then
                needSwitch = true
                print("Current pet is practice dog - switching")
            elseif isEgg(curPet["id"]) then
                -- If it's an egg and we have it equipped, try to hatch it
                print("Current pet is an egg - hatching:", curPet["id"])
                hatchEgg(PetID, curPet["id"])
                task.wait(2)
                -- After hatching, check again (might need new pet)
                needSwitch = true
            elseif curPet["properties"]["age"] == 6 then
                -- Full grown - might still keep for trading, but check if we have eggs to hatch
                local hasEggs = false
                for _, v in pairs(Pets) do
                    if v["id"] ~= "practice_dog" and isEgg(v["id"]) then
                        hasEggs = true
                        break
                    end
                end
                if hasEggs then
                    needSwitch = true
                    print("Current pet is full grown but we have eggs to hatch - switching")
                end
            end
        else
            needSwitch = true
        end
    else
        needSwitch = true
    end
    
    -- EGG FARM: Check if we need to buy new eggs
    if autoEggFarm then
        spawn(function()
            -- Count how many non-egg, non-practice pets we have
            local growableCount = 0
            local eggCount = 0
            
            for _, v in pairs(Pets) do
                if v["id"] ~= "practice_dog" then
                    if isEgg(v["id"]) then
                        eggCount = eggCount + 1
                    else
                        growableCount = growableCount + 1
                    end
                end
            end
            
            -- If we have no eggs AND no growable pets, buy a new egg
            if eggCount == 0 and growableCount == 0 then
                print("No eggs or growable pets - buying new egg:", eggToBuy)
                pcall(function()
                    RS.API:FindFirstChild("ShopAPI/BuyItem"):InvokeServer("pets", eggToBuy, {buy_count = 1})
                end)
                task.wait(2)
            end
        end)
    end

    -- Switch to new pet if needed
    if needSwitch then
        local best = getPetToFarm()
        if best then
            print("Switching to pet:", best["id"], "| Age:", best["properties"]["age"], "| IsEgg:", isEgg(best["id"]))
            changePetTo(best)
        else
            print("No suitable pet found to farm")
            -- If no pets at all, try to buy an egg
            if autoEggFarm then
                pcall(function()
                    RS.API:FindFirstChild("ShopAPI/BuyItem"):InvokeServer("pets", eggToBuy, {buy_count = 1})
                end)
                task.wait(2)
            end
        end
    end
    
    if Pet then
        local age = getPetAge(PetID)
        print("Current Pet:", Pet, "| ID:", PetID, "| Age:", age, "| IsEgg:", isEgg(PetID))
    else
        print("No pet equipped")
    end
end

