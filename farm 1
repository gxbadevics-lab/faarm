function getPetToFarm()
    local Pets = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.pets or {}
    local maxAge = 0
    local newPet = nil
    
    -- Egg farm mode: prioritize pets from the priority list
    if eggFarm then
        -- First try to find pets from priority list
        for _, petId in ipairs(eggFarmPriorityList) do
            for k,v in pairs(Pets) do
                if v['id'] == petId and v['id'] ~= "practice_dog" then
                    if v['properties']['age'] > maxAge and v['properties']['age'] < 6 then
                        maxAge = v['properties']['age']
                        newPet = v
                    end
                end
            end
            if newPet then break end
        end
        
        -- If no priority pets found, get any pet (fallback)
        if not newPet then
            for k,v in pairs(Pets) do
                if v['id'] ~= "practice_dog" then
                    if v['properties']['age'] > maxAge and v['properties']['age'] < 6 then
                        maxAge = v['properties']['age']
                        newPet = v
                    end
                end
            end
        end
    else
        -- Normal mode: prioritize neon pets first
        for k,v in pairs(Pets) do
            if v['id'] ~= "practice_dog" then
                if v['properties']['age'] > maxAge and v['properties']['age'] < 6 and v['properties']['neon'] then
                    maxAge = v['properties']['age']
                    newPet = v
                end
            end
        end
        if not newPet then
            for k,v in pairs(Pets) do
                if v['id'] ~= "practice_dog" then
                    if v['properties']['age'] > maxAge and v['properties']['age'] < 6 then
                        maxAge = v['properties']['age']
                        newPet = v
                    end
                end
            end
        end
    end
    
    if newPet then return newPet end
end

