local function hasTradeLicense()
    -- check inventory for trade_license toy (most reliable)
    local ok, toys = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.toys or {}
    end)
    if ok then
        for _, v in pairs(toys) do
            if v.id == "trade_license" then return true end
        end
    end
    return false
end

if not hasTradeLicense() then
    print("Getting trade license...")
    pcall(function()
        RS.API["SettingsAPI/SetBooleanFlag"]:FireServer("has_talked_to_trade_quest_npc", true)
        task.wait(0.5)
        local gotIt = false
        local tries = 0
        while not gotIt and tries < 10 do
            tries += 1
            -- try to read answers from ClientData
            local answered = false
            pcall(function()
                local quiz = ClientData.get_data()[Player.Name].trade_license_quiz_manager.quiz
                RS.API["TradeAPI/BeginQuiz"]:FireServer()
                task.wait(1)
                for _, qdata in pairs(quiz) do
                    RS.API["TradeAPI/AnswerQuizQuestion"]:FireServer(qdata["answer"])
                    task.wait(0.8)
                end
                answered = true
            end)
            if not answered then
                RS.API["TradeAPI/BeginQuiz"]:FireServer()
                task.wait(1)
                for _, ans in ipairs({"not safe","safe","not safe"}) do
                    RS.API["TradeAPI/AnswerQuizQuestion"]:FireServer(ans)
