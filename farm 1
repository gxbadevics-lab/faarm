local function equipAndUseFood(foodID)
    local Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
    local fu = nil
    for _, v in pairs(Foods) do if v.id == foodID then fu = v.unique break end end
    if not fu then
        -- buy it
        local buyArgs = {[1]="food",[2]=foodID,[3]={["buy_count"]=1}}
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("ShopAPI/BuyItem"):InvokeServer(unpack(buyArgs))
        task.wait(0.5)
        Foods = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[Player.Name].inventory.food or {}
        for _, v in pairs(Foods) do if v.id == foodID then fu = v.unique break end end
    end
    if fu then
        -- equip then use
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("ToolAPI/Equip"):InvokeServer(fu, {use_sound_delay=true, equip_as_last=false})
        task.wait(0.3)
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("ToolAPI/ServerUseTool"):FireServer(fu, "START")
        task.wait(0.5)
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("ToolAPI/ServerUseTool"):FireServer(fu, "END")
        task.wait(0.3)
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("ToolAPI/Unequip"):InvokeServer(fu)
        return true
    end
    return false
end

