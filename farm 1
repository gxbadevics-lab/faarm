            end)
            pcall(function()
                local seats = game.Workspace:FindFirstChild("ServerSidedMapSeats")
                if seats then seats:Destroy() end
            end)
            if Pet and not Pet.Parent then Pet = nil end
            checkIfINeedToChange()
            -- Update HUD
            spawn(function()
                pcall(function()
                    if Pet and PetID then
                        local Pets2 = ClientData.get_data()[Player.Name].inventory.pets or {}
                        if Pets2[tostring(PetID)] and infoPetFarming then
                            infoPetFarming.Text = "Farming: "..Pets2[PetID]["id"].." ("..Pet.Name..")"
                        end
                    elseif infoPetFarming then
                        infoPetFarming.Text = "Pet: Not Found"
                    end
                    local elapsed = os.difftime(os.time(), startTime)
                    local mins    = math.floor(elapsed / 60)
                    local hrs     = math.floor(mins / 60)
                    if infoTime then infoTime.Text = "Time: "..hrs.."h "..(mins%60).."min" end
                    local curText  = Player.PlayerGui.BucksIndicatorApp.CurrencyIndicator.Container.Amount.Text
                    local curBucks = tonumber((string.gsub(curText, ",", ""))) or 0
                    if infoBucksGained then infoBucksGained.Text = "Bucks Earned: "..(curBucks - startDinero) end
                end)
            end)
            task.wait(30)
        end
        task.wait(1)
    end
