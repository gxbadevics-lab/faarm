function CountPetsByName(displayName, petType)
    local c = 0
    local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
    if not ok then return 0 end
    for _, v in pairs(pets) do
        local nameMatch = findPetDisplayName(v.id) == displayName
        local typeMatch = false
        if petType == "normal" then
            typeMatch = not v.properties.neon and not v.properties.mega_neon
        elseif petType == "neon" then
            typeMatch = v.properties.neon and not v.properties.mega_neon
        elseif petType == "mega" then
            typeMatch = v.properties.mega_neon == true
        end
        if nameMatch and typeMatch then c += 1 end
        task.wait()
    end
    return c
end

