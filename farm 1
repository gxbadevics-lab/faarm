local function getFullgrownPets(forMega)
    local result = {}
    local ok, pets = pcall(function() return ClientData.get_data()[Player.Name].inventory.pets end)
    if not ok then return result end
    for _, v in pairs(pets) do
        local match = false
        if forMega then
            match = v.properties.age == 6 and v.properties.neon and not v.properties.mega_neon
        else
            match = v.properties.age == 6 and not v.properties.neon and not v.properties.mega_neon
        end
        if match then
            if not result[v.id] then result[v.id] = {count=0, unique={}} end
            result[v.id].count += 1
            table.insert(result[v.id].unique, v.unique)
        end
    end
    return result
end

function MakeMega(forMega)
    local groups = getFullgrownPets(forMega)
    for _, g in pairs(groups) do
        if g.count >= 4 then
            local fusionReady = {g.unique[1], g.unique[2], g.unique[3], g.unique[4]}
            pcall(function()
                RS.API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer({unpack(fusionReady)})
            end)
            task.wait(1)
        end
    end
end

