-- ============================================================
-- PATCHED: checkIfINeedToChange
-- Unified egg+pet switching — 4-step flow:
--   1) Hatch currently equipped egg if needed
--   2) Buy+hatch egg if autoEggFarm and nothing left to grow
--   3) Decide if switch needed
--   4) Pick best next target; if it's an egg, hatch then switch to result
-- ============================================================
function checkIfINeedToChange()
    local ok, Pets = pcall(function()
        return ClientData.get_data()[Player.Name].inventory.pets or {}
    end)
    if not ok then return end

    -- ── Step 1: if autoEggFarm and nothing to farm at all, buy an egg ──
    if autoEggFarm then
        local hasFarmable = false
        for _, v in pairs(Pets) do
            if v["id"] ~= "practice_dog" then
                -- eggs count, and so do non-full-grown pets
                if isEgg(v["id"]) or v["properties"]["age"] < 6 then
                    hasFarmable = true
                    break
                end
            end
        end
        if not hasFarmable then
            print("[Farm] Nothing to farm — buying egg:", eggToBuy)
            pcall(function()
                RS.API:FindFirstChild("ShopAPI/BuyItem"):InvokeServer("pets", eggToBuy, {buy_count = 1})
            end)
            task.wait(1.5)
            -- refresh
            ok, Pets = pcall(function()
                return ClientData.get_data()[Player.Name].inventory.pets or {}
            end)
            if not ok then Pets = {} end
            Pet   = nil
            PetID = nil
        end
    end

    -- ── Step 2: decide if we need to switch ──
    local needSwitch = not Pet or not PetID
    if Pet and PetID then
        local ok2, curPet = pcall(function()
            return ClientData.get_data()[Player.Name].inventory.pets[tostring(PetID)]
        end)
        if ok2 and curPet then
            -- switch only when current pet is full grown (age 6) AND not an egg
            -- eggs stay equipped until they hatch (they'll disappear from inventory)
            if not isEgg(curPet["id"]) and curPet["properties"]["age"] == 6 then
                needSwitch = true
            end
            -- if the pet no longer exists (hatched egg removed from inv) also switch
        else
            needSwitch = true
        end
    end

    -- ── Step 3: equip the best farmable target ──
    if needSwitch then
        local best = getPetToFarm()
        if best then
            changePetTo(best)
            if isEgg(best["id"]) then
                print("[Farm] Egg equipped — doing tasks to hatch:", best["id"])
            end
        else
            -- absolute fallback: anything in inventory
            for _, v in pairs(Pets) do
                if v["id"] ~= "practice_dog" then
                    changePetTo(v)
                    break
                end
            end
        end
    end

    print("Pet:", Pet, "| ID:", PetID)
end

