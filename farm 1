-- Find Location function safely
local Location = nil
pcall(function()
    for i, v in pairs(getgc()) do
        if type(v) == "function" then
            local env = getfenv(v)
            if env and env.script == ReplicatedStorage.ClientModules.Core.InteriorsM.InteriorsM then
                local constants = getconstants(v)
                if constants and table.find(constants, "LocationAPI/SetLocation") then
                    Location = v
                    break
                end
            end
        end
    end
end)

local function SetLocation(a, b, c)
    if not Location then return false end
    local k = get_thread_identity and get_thread_identity() or 2
    pcall(set_thread_identity, 2)
    wait()
    pcall(Location, a, b, c)
    pcall(set_thread_identity, k)
    wait()
    return true
end

function GoToHome()
    if not Location then 
        print("Location function not found")
        return false 
    end
    return SetLocation("housing", "MainDoor", {["house_owner"] = Player})
end

function createLabel(frame, position, text)
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(0, 300, 0, 50)
    textLabel.Position = UDim2.new(0.5, 0, position, 0)
    textLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    textLabel.TextScaled = true
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.Text = text
    textLabel.BackgroundTransparency = 1
    textLabel.ZIndex = 11
    textLabel.Parent = frame
    return textLabel
end

-- Baby farm functions
function isPlayerBaby()
    local playerTeam = Player.Team
    if playerTeam and playerTeam.Name == "Babies" then
        return true
    end
    return false
end

function becomeBaby()
    print("Attempting to become baby...")
    local success = pcall(function()
        local api = ReplicatedStorage.API:FindFirstChild("AdoptAPI/BecomeBaby")
        if api then
            api:FireServer()
        end
    end)
    
    if not success then
